FROM node:22-bookworm-slim

ENV PNPM_HOME="/pnpm"
ENV PATH="${PNPM_HOME}:${PATH}"
ENV PORT=8080

WORKDIR /app

RUN corepack enable

COPY . .

# This is an explicit manual scaffold, not a slim production image.
# The current hosted runner still starts from repo source via tsx.
RUN pnpm install --frozen-lockfile

EXPOSE 8080

CMD ["pnpm", "--dir", "apps/cloudflare", "runner:local"]

