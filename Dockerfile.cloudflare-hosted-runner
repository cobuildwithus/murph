FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    HOME=/home/runner \
    NODE_ENV=production \
    PORT=8080 \
    XDG_CACHE_HOME=/home/runner/.cache \
    HOSTED_HOME=/home/runner/.murph \
    HOSTED_MODELS_ROOT=/home/runner/.murph/models \
    FFMPEG_COMMAND=/usr/bin/ffmpeg \
    HF_HOME=/home/runner/.cache/huggingface

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    poppler-utils \
    python3 \
    python3-pip \
    python3-venv \
  && useradd --create-home --home-dir /home/runner --shell /bin/bash runner \
  && mkdir -p \
    /home/runner/.cache/huggingface \
    /home/runner/.murph/hosted \
    /home/runner/.murph/models/whisper \
  && chown -R runner:runner /home/runner \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig*.json AGENTS.md ARCHITECTURE.md README.md ./
COPY scripts ./scripts
COPY config ./config
COPY agent-docs ./agent-docs
COPY docs ./docs
COPY packages ./packages
COPY apps ./apps
COPY fixtures ./fixtures
COPY e2e ./e2e

RUN corepack enable \
  && corepack prepare pnpm@9.15.9 --activate \
  && pnpm install --frozen-lockfile

USER runner

EXPOSE 8080

# This image intentionally keeps the current source-based hosted execution path.
# The baked /app tree stays root-owned while the runtime executes as a dedicated
# non-root user, so hosted jobs must use temp/vault paths instead of mutating
# shipped source in warm containers.
CMD ["node", "--import", "tsx", "apps/cloudflare/src/container-entrypoint.ts"]
