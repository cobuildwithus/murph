FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PORT=8080

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    poppler-utils \
    python3 \
    python3-pip \
    python3-venv \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig*.json AGENTS.md ARCHITECTURE.md README.md ./
COPY scripts ./scripts
COPY agent-docs ./agent-docs
COPY docs ./docs
COPY packages ./packages
COPY apps ./apps
COPY fixtures ./fixtures
COPY e2e ./e2e

RUN corepack enable \
  && corepack prepare pnpm@9.15.9 --activate \
  && pnpm install --frozen-lockfile

EXPOSE 8080

# This image intentionally keeps the current source-based runner startup path.
# Provider credentials, parser-toolchain paths, and model directories are supplied
# at runtime through environment variables or mounted under /root/.healthybob.
CMD ["bash", "-lc", "corepack pnpm --dir apps/cloudflare runner:local"]
