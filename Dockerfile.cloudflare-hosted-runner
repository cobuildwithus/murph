ARG WHISPER_CPP_VERSION=v1.8.1
ARG WHISPER_MODEL_FILE=ggml-base.en.bin

FROM node:22-bookworm-slim AS whisper-builder

ARG WHISPER_CPP_VERSION
ARG WHISPER_MODEL_FILE

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    cmake \
    curl \
    g++ \
    make \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/whisper.cpp

RUN curl -fsSL --retry 5 --retry-delay 2 \
    "https://github.com/ggml-org/whisper.cpp/archive/refs/tags/${WHISPER_CPP_VERSION}.tar.gz" \
    | tar -xz --strip-components=1 \
  && cmake -B build -DCMAKE_BUILD_TYPE=Release \
  && cmake --build build -j"$(nproc)" --config Release --target whisper-cli \
  && install -Dm755 build/bin/whisper-cli /opt/whisper/whisper-cli \
  && curl -fsSL --retry 5 --retry-delay 2 \
    "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/${WHISPER_MODEL_FILE}" \
    -o "/opt/whisper/${WHISPER_MODEL_FILE}"

FROM node:22-bookworm-slim

ARG WHISPER_MODEL_FILE

ENV DEBIAN_FRONTEND=noninteractive \
    HOME=/home/runner \
    NODE_ENV=production \
    PORT=8080 \
    XDG_CACHE_HOME=/home/runner/.cache \
    HOSTED_HOME=/home/runner/.murph \
    HOSTED_MODELS_ROOT=/home/runner/.murph/models \
    FFMPEG_COMMAND=/usr/bin/ffmpeg \
    PDFTOTEXT_COMMAND=/usr/bin/pdftotext \
    WHISPER_COMMAND=/usr/local/bin/whisper-cli \
    WHISPER_MODEL_PATH=/home/runner/.murph/models/whisper/ggml-base.en.bin \
    HF_HOME=/home/runner/.cache/huggingface

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    poppler-utils \
    python3 \
    python3-pip \
    python3-venv \
  && useradd --create-home --home-dir /home/runner --shell /bin/bash runner \
  && mkdir -p \
    /home/runner/.cache/huggingface \
    /home/runner/.murph/hosted \
    /home/runner/.murph/models/whisper \
  && chown -R runner:runner /home/runner \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=whisper-builder /opt/whisper/whisper-cli /usr/local/bin/whisper-cli
COPY --from=whisper-builder --chown=runner:runner /opt/whisper/${WHISPER_MODEL_FILE} /home/runner/.murph/models/whisper/${WHISPER_MODEL_FILE}

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig*.json AGENTS.md ARCHITECTURE.md README.md ./
COPY scripts ./scripts
COPY config ./config
COPY agent-docs ./agent-docs
COPY docs ./docs
COPY packages ./packages
COPY apps ./apps
COPY fixtures ./fixtures
COPY e2e ./e2e

RUN corepack enable \
  && corepack prepare pnpm@9.15.9 --activate \
  && pnpm install --frozen-lockfile

USER runner

EXPOSE 8080

# This image intentionally keeps the current source-based hosted execution path.
# The baked /app tree stays root-owned while the runtime executes as a dedicated
# non-root user, so hosted jobs must use temp/vault paths instead of mutating
# shipped source in warm containers.
CMD ["node", "--import", "tsx", "apps/cloudflare/src/container-entrypoint.ts"]
