{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": false,
    "baseUrl": "../..",
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@healthybob/contracts": [
        "packages/contracts/dist/index.d.ts"
      ],
      "@healthybob/contracts/*": [
        "packages/contracts/dist/*"
      ],
      "@healthybob/query": [
        "packages/query/dist/index.d.ts"
      ],
      "@healthybob/query/*": [
        "packages/query/dist/*"
      ],
      "@healthybob/runtime-state": [
        "packages/runtime-state/dist/index.d.ts"
      ],
      "@healthybob/runtime-state/*": [
        "packages/runtime-state/dist/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "sourceMap": false,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
