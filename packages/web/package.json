{
  "name": "@murph/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build:app": "pnpm --dir ../.. exec tsx packages/web/scripts/next-local.ts build",
    "dev": "pnpm --dir ../.. exec tsx packages/web/scripts/next-local.ts dev",
    "build": "pnpm build:app",
    "start": "pnpm --dir ../.. exec tsx packages/web/scripts/next-local.ts start",
    "typecheck": "pnpm --dir ../.. exec tsx scripts/ensure-next-route-type-stubs.ts packages/web && tsc -p tsconfig.json --pretty false",
    "test": "pnpm typecheck && pnpm --dir ../.. exec vitest run --config packages/web/vitest.config.ts --no-coverage --maxWorkers 1 && pnpm build:app"
  },
  "dependencies": {
    "@murph/contracts": "workspace:*",
    "@murph/query": "workspace:*",
    "@murph/runtime-state": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
