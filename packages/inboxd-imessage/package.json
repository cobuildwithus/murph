{
  "name": "@murphai/inboxd-imessage",
  "version": "0.1.16",
  "private": true,
  "description": "Optional iMessage connector runtime for Murph inbox ingestion.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@murphai/inboxd": "workspace:*",
    "@photon-ai/imessage-kit": "2.1.2"
  }
}
