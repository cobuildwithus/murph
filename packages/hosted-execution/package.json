{
  "name": "@murphai/hosted-execution",
  "version": "0.2.6",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "default": "./dist/contracts.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./hosted-email": {
      "types": "./dist/hosted-email.d.ts",
      "default": "./dist/hosted-email.js"
    },
    "./parsers": {
      "types": "./dist/parsers.d.ts",
      "default": "./dist/parsers.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "default": "./dist/routes.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist .tsbuildinfo && tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "dependencies": {
    "@murphai/core": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/gateway-core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "zod": "^4.1.8"
  },
  "bundleDependencies": [
    "@murphai/core",
    "@murphai/device-syncd",
    "@murphai/importers",
    "@murphai/runtime-state"
  ]
}
