{
  "name": "@murphai/hosted-execution",
  "version": "0.1.16",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./callback-hosts": {
      "types": "./dist/callback-hosts.d.ts",
      "default": "./dist/callback-hosts.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "default": "./dist/contracts.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./hosted-email": {
      "types": "./dist/hosted-email.d.ts",
      "default": "./dist/hosted-email.js"
    },
    "./parsers": {
      "types": "./dist/parsers.d.ts",
      "default": "./dist/parsers.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "default": "./dist/routes.js"
    },
    "./web-control-plane": {
      "types": "./dist/web-control-plane.d.ts",
      "default": "./dist/web-control-plane.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@murphai/contracts": "workspace:*",
    "@murphai/runtime-state": "workspace:*"
  },
  "bundleDependencies": [
    "@murphai/runtime-state"
  ]
}
