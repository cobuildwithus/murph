{
  "name": "@murphai/setup-cli",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./setup-cli": {
      "types": "./dist/setup-cli.d.ts",
      "default": "./dist/setup-cli.js"
    },
    "./setup-assistant": {
      "types": "./dist/setup-assistant.d.ts",
      "default": "./dist/setup-assistant.js"
    },
    "./setup-assistant-wizard": {
      "types": "./dist/setup-assistant-wizard.d.ts",
      "default": "./dist/setup-assistant-wizard.js"
    },
    "./setup-assistant-defaults": {
      "types": "./dist/setup-assistant-defaults.d.ts",
      "default": "./dist/setup-assistant-defaults.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@murphai/assistant-engine": "workspace:*",
    "@murphai/inbox-services": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/vault-usecases": "workspace:*",
    "incur": "0.3.13",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
