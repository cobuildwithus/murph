{
  "name": "@murphai/setup-cli",
  "version": "0.1.16",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./setup-cli": {
      "types": "./dist/setup-cli.d.ts",
      "default": "./dist/setup-cli.js"
    },
    "./setup-services": {
      "types": "./dist/setup-services.d.ts",
      "default": "./dist/setup-services.js"
    },
    "./setup-assistant": {
      "types": "./dist/setup-assistant.d.ts",
      "default": "./dist/setup-assistant.js"
    },
    "./setup-assistant-account": {
      "types": "./dist/setup-assistant-account.d.ts",
      "default": "./dist/setup-assistant-account.js"
    },
    "./setup-agentmail": {
      "types": "./dist/setup-agentmail.d.ts",
      "default": "./dist/setup-agentmail.js"
    },
    "./setup-wizard": {
      "types": "./dist/setup-wizard.d.ts",
      "default": "./dist/setup-wizard.js"
    },
    "./setup-services/*": {
      "types": "./dist/setup-services/*.d.ts",
      "default": "./dist/setup-services/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --passWithNoTests --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@murphai/assistant-core": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "incur": "0.3.13",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
