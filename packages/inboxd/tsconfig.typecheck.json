{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../..",
    "composite": false,
    "incremental": true,
    "tsBuildInfoFile": "typecheck.tsbuildinfo"
  },
  "references": [
    {
      "path": "../messaging-ingress"
    },
    {
      "path": "../contracts/tsconfig.build.json"
    },
    {
      "path": "../core/tsconfig.build.json"
