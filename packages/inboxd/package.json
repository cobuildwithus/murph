{
  "name": "@murphai/inboxd",
  "version": "0.1.16",
  "private": false,
  "description": "Local inbox ingestion runtime for Murph.",
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./connectors/email/normalize-parsed": {
      "types": "./dist/connectors/email/normalize-parsed.d.ts",
      "default": "./dist/connectors/email/normalize-parsed.js"
    },
    "./connectors/email/parsed": {
      "types": "./dist/connectors/email/parsed.d.ts",
      "default": "./dist/connectors/email/parsed.js"
    },
    "./connectors/linq/normalize": {
      "types": "./dist/connectors/linq/normalize.d.ts",
      "default": "./dist/connectors/linq/normalize.js"
    },
    "./connectors/telegram/normalize": {
      "types": "./dist/connectors/telegram/normalize.d.ts",
      "default": "./dist/connectors/telegram/normalize.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@photon-ai/imessage-kit": "2.1.2",
    "grammy": "1.41.1"
  }
}
