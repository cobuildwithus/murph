{
  "name": "@murph/assistant-services",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./automation": {
      "types": "./dist/automation.d.ts",
      "import": "./dist/automation.js",
      "default": "./dist/automation.js"
    },
    "./cron": {
      "types": "./dist/cron.d.ts",
      "import": "./dist/cron.js",
      "default": "./dist/cron.js"
    },
    "./inbox-services": {
      "types": "./dist/inbox-services.d.ts",
      "import": "./dist/inbox-services.js",
      "default": "./dist/inbox-services.js"
    },
    "./operator-config": {
      "types": "./dist/operator-config.d.ts",
      "import": "./dist/operator-config.js",
      "default": "./dist/operator-config.js"
    },
    "./outbox": {
      "types": "./dist/outbox.d.ts",
      "import": "./dist/outbox.js",
      "default": "./dist/outbox.js"
    },
    "./status": {
      "types": "./dist/status.d.ts",
      "import": "./dist/status.js",
      "default": "./dist/status.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js",
      "default": "./dist/store.js"
    },
    "./vault-services": {
      "types": "./dist/vault-services.d.ts",
      "import": "./dist/vault-services.js",
      "default": "./dist/vault-services.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false"
  },
  "dependencies": {
    "murph": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
