{
  "name": "@murphai/vault-usecases",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vault-services": {
      "types": "./dist/vault-services.d.ts",
      "default": "./dist/vault-services.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "default": "./dist/helpers.js"
    },
    "./assistant-vault-paths": {
      "types": "./dist/assistant-vault-paths.d.ts",
      "default": "./dist/assistant-vault-paths.js"
    },
    "./records": {
      "types": "./dist/records.d.ts",
      "default": "./dist/records.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./workouts": {
      "types": "./dist/workouts.d.ts",
      "default": "./dist/workouts.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/inboxd-imessage": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/query": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "zod": "^4.1.8"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
