{
  "name": "@murphai/assistant-engine",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assistant-automation": {
      "types": "./dist/assistant-automation.d.ts",
      "default": "./dist/assistant-automation.js"
    },
