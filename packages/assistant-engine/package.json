      "types": "./dist/assistant-vault-paths.d.ts",
      "default": "./dist/assistant-vault-paths.js"
    },
    "./assistant/*": {
      "types": "./dist/assistant/*.d.ts",
      "default": "./dist/assistant/*.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*.d.ts",
      "default": "./dist/commands/*.js"
    },
    "./child-process-env": {
      "types": "./dist/child-process-env.d.ts",
      "default": "./dist/child-process-env.js"
    },
    "./gateway-local-adapter": {
      "types": "./dist/gateway-local-adapter.d.ts",
      "default": "./dist/gateway-local-adapter.js"
    },
    "./inbox-model-contracts": {
      "types": "./dist/inbox-model-contracts.d.ts",
      "default": "./dist/inbox-model-contracts.js"
    },
    "./inbox-model-harness": {
      "types": "./dist/inbox-model-harness.d.ts",
      "default": "./dist/inbox-model-harness.js"
    },
    "./model-harness": {
      "types": "./dist/model-harness.d.ts",
      "default": "./dist/model-harness.js"
    },
    "./outbound-channel": {
      "types": "./dist/outbound-channel.d.ts",
      "default": "./dist/outbound-channel.js"
    },
    "./process-kill": {
      "types": "./dist/process-kill.d.ts",
      "default": "./dist/process-kill.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.35",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "0.6.0",
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/gateway-core": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@murphai/hosted-execution": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/query": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "ai": "^6.0.116",
    "linkedom": "0.18.12",
    "pdfjs-dist": "5.6.205",
    "zod": "^4.1.8"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
