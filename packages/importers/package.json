{
  "name": "@healthybob/importers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.json",
    "typecheck": "pnpm --dir ../core build && tsc -p tsconfig.typecheck.json --pretty false",
    "test": "node --import=tsx --test ./test/*.test.ts"
  },
  "dependencies": {
    "@healthybob/core": "workspace:*"
  }
}
