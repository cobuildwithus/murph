{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "composite": false,
    "incremental": false,
    "paths": {
      "@murph/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@murph/contracts/schemas": [
        "packages/contracts/src/schemas.ts"
      ],
      "@murph/contracts/*": [
        "packages/contracts/src/*.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "generated"
  ]
}
