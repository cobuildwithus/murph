{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@murphai/contracts": [
        "./dist/index.d.ts"
      ],
      "@murphai/contracts/schemas": [
        "./dist/schemas.d.ts"
      ]
    },
    "noEmit": false,
    "rootDir": "scripts",
    "outDir": "dist/scripts",
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "generated"
  ]
}
