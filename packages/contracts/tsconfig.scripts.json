{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "rootDir": "scripts",
    "outDir": "dist/scripts",
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@healthybob/contracts": [
        "packages/contracts/dist/index.d.ts"
      ],
      "@healthybob/contracts/*": [
        "packages/contracts/dist/*"
      ]
    }
  },
  "include": [
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "generated"
  ]
}
