{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.protocol.v1"
    },
    "docType": {
      "type": "string",
      "const": "protocol"
    },
    "protocolId": {
      "type": "string",
      "pattern": "^prot_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "kind": {
      "type": "string",
      "enum": [
        "medication",
        "supplement",
        "therapy",
        "habit"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "completed",
        "stopped"
      ]
    },
    "startedOn": {
      "type": "string",
      "format": "date"
    },
    "stoppedOn": {
      "type": "string",
      "format": "date"
    },
    "substance": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "dose": {
      "type": "number",
      "minimum": 0
    },
    "unit": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/%-]+$"
    },
    "schedule": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "brand": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "servingSize": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "compound": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._/%-]+$"
          },
          "active": {
            "type": "boolean"
          },
          "note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          }
        },
        "required": [
          "compound"
        ],
        "additionalProperties": false
      }
    },
    "relatedGoalIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "relatedConditionIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^cond_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "protocolId",
    "slug",
    "title",
    "kind",
    "status",
    "startedOn"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/frontmatter-protocol.schema.json",
  "title": "Murph Protocol Frontmatter"
}
