{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.allergy.v1"
    },
    "docType": {
      "type": "string",
      "const": "allergy"
    },
    "allergyId": {
      "type": "string",
      "pattern": "^alg_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "substance": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "resolved"
      ]
    },
    "criticality": {
      "type": "string",
      "enum": [
        "low",
        "high",
        "unable_to_assess"
      ]
    },
    "reaction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "recordedOn": {
      "type": "string",
      "format": "date"
    },
    "relatedConditionIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^cond_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "related_condition"
          },
          "targetId": {
            "type": "string",
            "pattern": "^cond_[0-9A-HJKMNP-TV-Z]{26}$"
          }
        },
        "required": [
          "type",
          "targetId"
        ],
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "allergyId",
    "slug",
    "title",
    "substance",
    "status"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/frontmatter-allergy.schema.json",
  "title": "Murph Allergy Frontmatter"
}
