{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.provider.v1"
    },
    "docType": {
      "type": "string",
      "const": "provider"
    },
    "providerId": {
      "type": "string",
      "pattern": "^prov_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "specialty": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "organization": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "website": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "phone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "providerId",
    "slug",
    "title"
  ],
  "additionalProperties": false,
  "$id": "@murph/contracts/frontmatter-provider.schema.json",
  "title": "Murph Provider Frontmatter"
}
