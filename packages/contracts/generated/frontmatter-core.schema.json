{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.core.v1"
    },
    "docType": {
      "type": "string",
      "const": "core"
    },
    "vaultId": {
      "type": "string",
      "pattern": "^vault_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "timezone": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "activeExperimentSlugs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "vaultId",
    "title",
    "timezone",
    "updatedAt"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/frontmatter-core.schema.json",
  "title": "Murph CORE Frontmatter"
}
