{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.workout-format.v1"
    },
    "docType": {
      "type": "string",
      "const": "workout_format"
    },
    "workoutFormatId": {
      "type": "string",
      "pattern": "^wfmt_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "activityType": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "durationMinutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440
    },
    "distanceKm": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "template": {
      "type": "object",
      "properties": {
        "routineNote": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "exercises": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "order": {
                "type": "integer",
                "minimum": 1
              },
              "groupId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              },
              "mode": {
                "type": "string",
                "enum": [
                  "weight_reps",
                  "bodyweight",
                  "assisted_bodyweight",
                  "weighted_bodyweight",
                  "duration",
                  "cardio"
                ]
              },
              "unitOverride": {
                "type": "string",
                "enum": [
                  "lb",
                  "kg"
                ]
              },
              "note": {
                "type": "string",
                "minLength": 1,
                "maxLength": 4000
              },
              "plannedSets": {
                "minItems": 1,
                "maxItems": 150,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "order": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "normal",
                        "warmup",
                        "dropset",
                        "failure"
                      ]
                    },
                    "targetReps": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "targetWeight": {
                      "type": "number",
                      "minimum": 0
                    },
                    "targetWeightUnit": {
                      "type": "string",
                      "enum": [
                        "lb",
                        "kg"
                      ]
                    },
                    "targetDurationSeconds": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "targetDistanceMeters": {
                      "type": "number",
                      "minimum": 0
                    },
                    "targetRpe": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 10
                    }
                  },
                  "required": [
                    "order"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "name",
              "order",
              "plannedSets"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "exercises"
      ],
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "templateText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "workoutFormatId",
    "slug",
    "title",
    "status",
    "activityType",
    "template"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/frontmatter-workout-format.schema.json",
  "title": "Murph Workout Format Frontmatter"
}
