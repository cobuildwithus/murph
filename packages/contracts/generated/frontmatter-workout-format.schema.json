{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.workout-format.v1"
    },
    "docType": {
      "type": "string",
      "const": "workout_format"
    },
    "workoutFormatId": {
      "type": "string",
      "pattern": "^wfmt_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "activityType": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "durationMinutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440
    },
    "distanceKm": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "strengthExercises": {
      "minItems": 1,
      "maxItems": 50,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "exercise": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "setCount": {
                "type": "integer",
                "minimum": 1
              },
              "repsPerSet": {
                "type": "integer",
                "minimum": 1
              },
              "loadDescription": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              }
            },
            "required": [
              "exercise",
              "setCount",
              "repsPerSet"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "exercise": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "setCount": {
                "type": "integer",
                "minimum": 1
              },
              "repsPerSet": {
                "type": "integer",
                "minimum": 1
              },
              "loadDescription": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "load": {
                "type": "number",
                "minimum": 0
              },
              "loadUnit": {
                "type": "string",
                "enum": [
                  "lb",
                  "kg"
                ]
              }
            },
            "required": [
              "exercise",
              "setCount",
              "repsPerSet",
              "load",
              "loadUnit"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "templateText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "workoutFormatId",
    "slug",
    "title",
    "status",
    "activityType"
  ],
  "additionalProperties": false,
  "$id": "@murph/contracts/frontmatter-workout-format.schema.json",
  "title": "Murph Workout Format Frontmatter"
}
