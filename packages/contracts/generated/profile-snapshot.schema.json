{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.profile-snapshot.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^psnap_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "assessment_projection",
        "manual",
        "derived"
      ]
    },
    "sourceAssessmentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^asmt_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "sourceEventIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "profile": {
      "type": "object",
      "properties": {
        "narrative": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            "highlights": {
              "maxItems": 25,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "goals": {
          "type": "object",
          "properties": {
            "topGoalIds": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "custom": {
          "type": "object",
          "properties": {},
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "recordedAt",
    "source",
    "profile"
  ],
  "additionalProperties": false,
  "$id": "@murph/contracts/profile-snapshot.schema.json",
  "title": "Murph Profile Snapshot",
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "properties": {},
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
