{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "hb.profile-snapshot.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^psnap_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "assessment_projection",
        "manual",
        "derived"
      ]
    },
    "sourceAssessmentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^asmt_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "sourceEventIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "profile": {
      "type": "object",
      "properties": {},
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      }
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "recordedAt",
    "source",
    "profile"
  ],
  "additionalProperties": false,
  "$id": "@healthybob/contracts/profile-snapshot.schema.json",
  "title": "Healthy Bob Profile Snapshot",
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "properties": {},
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
