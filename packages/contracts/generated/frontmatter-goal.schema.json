{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.frontmatter.goal.v1"
    },
    "docType": {
      "type": "string",
      "const": "goal"
    },
    "goalId": {
      "type": "string",
      "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "completed",
        "abandoned"
      ]
    },
    "horizon": {
      "type": "string",
      "enum": [
        "short_term",
        "medium_term",
        "long_term",
        "ongoing"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "window": {
      "type": "object",
      "properties": {
        "startAt": {
          "type": "string",
          "format": "date"
        },
        "targetAt": {
          "type": "string",
          "format": "date"
        }
      },
      "required": [
        "startAt"
      ],
      "additionalProperties": false
    },
    "parentGoalId": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "relatedGoalIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "relatedExperimentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^exp_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "parent_goal"
              },
              "targetId": {
                "type": "string",
                "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            },
            "required": [
              "type",
              "targetId"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "related_goal"
              },
              "targetId": {
                "type": "string",
                "pattern": "^goal_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            },
            "required": [
              "type",
              "targetId"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "related_experiment"
              },
              "targetId": {
                "type": "string",
                "pattern": "^exp_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            },
            "required": [
              "type",
              "targetId"
            ],
            "additionalProperties": false
          }
        ]
      },
      "uniqueItems": true
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "docType",
    "goalId",
    "slug",
    "title",
    "status",
    "horizon",
    "priority",
    "window"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/frontmatter-goal.schema.json",
  "title": "Murph Goal Frontmatter"
}
