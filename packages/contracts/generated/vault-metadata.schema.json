{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "formatVersion": {
      "type": "number",
      "const": 1
    },
    "vaultId": {
      "type": "string",
      "pattern": "^vault_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "timezone": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    }
  },
  "required": [
    "formatVersion",
    "vaultId",
    "createdAt",
    "title",
    "timezone"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/vault-metadata.schema.json",
  "title": "Murph Vault Metadata"
}
