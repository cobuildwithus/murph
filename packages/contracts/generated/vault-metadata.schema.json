{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.vault.v1"
    },
    "formatVersion": {
      "type": "number",
      "const": 1
    },
    "vaultId": {
      "type": "string",
      "pattern": "^vault_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "timezone": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    },
    "idPolicy": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "const": "prefix_ulid"
        },
        "prefixes": {
          "type": "object",
          "properties": {
            "allergy": {
              "type": "string",
              "const": "alg"
            },
            "assessment": {
              "type": "string",
              "const": "asmt"
            },
            "audit": {
              "type": "string",
              "const": "aud"
            },
            "automation": {
              "type": "string",
              "const": "automation"
            },
            "condition": {
              "type": "string",
              "const": "cond"
            },
            "document": {
              "type": "string",
              "const": "doc"
            },
            "event": {
              "type": "string",
              "const": "evt"
            },
            "experiment": {
              "type": "string",
              "const": "exp"
            },
            "family": {
              "type": "string",
              "const": "fam"
            },
            "food": {
              "type": "string",
              "const": "food"
            },
            "goal": {
              "type": "string",
              "const": "goal"
            },
            "meal": {
              "type": "string",
              "const": "meal"
            },
            "memory": {
              "type": "string",
              "const": "mem"
            },
            "pack": {
              "type": "string",
              "const": "pack"
            },
            "profileSnapshot": {
              "type": "string",
              "const": "psnap"
            },
            "provider": {
              "type": "string",
              "const": "prov"
            },
            "recipe": {
              "type": "string",
              "const": "rcp"
            },
            "protocol": {
              "type": "string",
              "const": "prot"
            },
            "sample": {
              "type": "string",
              "const": "smp"
            },
            "transform": {
              "type": "string",
              "const": "xfm"
            },
            "variant": {
              "type": "string",
              "const": "var"
            },
            "vault": {
              "type": "string",
              "const": "vault"
            },
            "workoutFormat": {
              "type": "string",
              "const": "wfmt"
            }
          },
          "required": [
            "allergy",
            "assessment",
            "audit",
            "automation",
            "condition",
            "document",
            "event",
            "experiment",
            "family",
            "food",
            "goal",
            "meal",
            "memory",
            "pack",
            "profileSnapshot",
            "provider",
            "recipe",
            "protocol",
            "sample",
            "transform",
            "variant",
            "vault",
            "workoutFormat"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "format",
        "prefixes"
      ],
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "properties": {
        "allergiesRoot": {
          "type": "string",
          "const": "bank/allergies"
        },
        "assessmentLedgerRoot": {
          "type": "string",
          "const": "ledger/assessments"
        },
        "conditionsRoot": {
          "type": "string",
          "const": "bank/conditions"
        },
        "coreDocument": {
          "type": "string",
          "const": "CORE.md"
        },
        "familyRoot": {
          "type": "string",
          "const": "bank/family"
        },
        "foodsRoot": {
          "type": "string",
          "const": "bank/foods"
        },
        "geneticsRoot": {
          "type": "string",
          "const": "bank/genetics"
        },
        "goalsRoot": {
          "type": "string",
          "const": "bank/goals"
        },
        "journalRoot": {
          "type": "string",
          "const": "journal"
        },
        "experimentsRoot": {
          "type": "string",
          "const": "bank/experiments"
        },
        "profileCurrentDocument": {
          "type": "string",
          "const": "bank/profile/current.md"
        },
        "profileRoot": {
          "type": "string",
          "const": "bank/profile"
        },
        "profileSnapshotsRoot": {
          "type": "string",
          "const": "ledger/profile-snapshots"
        },
        "providersRoot": {
          "type": "string",
          "const": "bank/providers"
        },
        "recipesRoot": {
          "type": "string",
          "const": "bank/recipes"
        },
        "workoutFormatsRoot": {
          "type": "string",
          "const": "bank/workout-formats"
        },
        "rawAssessmentsRoot": {
          "type": "string",
          "const": "raw/assessments"
        },
        "rawRoot": {
          "type": "string",
          "const": "raw"
        },
        "eventsRoot": {
          "type": "string",
          "const": "ledger/events"
        },
        "protocolsRoot": {
          "type": "string",
          "const": "bank/protocols"
        },
        "samplesRoot": {
          "type": "string",
          "const": "ledger/samples"
        },
        "auditRoot": {
          "type": "string",
          "const": "audit"
        },
        "exportsRoot": {
          "type": "string",
          "const": "exports"
        }
      },
      "required": [
        "allergiesRoot",
        "assessmentLedgerRoot",
        "conditionsRoot",
        "coreDocument",
        "familyRoot",
        "foodsRoot",
        "geneticsRoot",
        "goalsRoot",
        "journalRoot",
        "experimentsRoot",
        "profileCurrentDocument",
        "profileRoot",
        "profileSnapshotsRoot",
        "providersRoot",
        "recipesRoot",
        "workoutFormatsRoot",
        "rawAssessmentsRoot",
        "rawRoot",
        "eventsRoot",
        "protocolsRoot",
        "samplesRoot",
        "auditRoot",
        "exportsRoot"
      ],
      "additionalProperties": false
    },
    "shards": {
      "type": "object",
      "properties": {
        "assessments": {
          "type": "string",
          "const": "ledger/assessments/YYYY/YYYY-MM.jsonl"
        },
        "events": {
          "type": "string",
          "const": "ledger/events/YYYY/YYYY-MM.jsonl"
        },
        "profileSnapshots": {
          "type": "string",
          "const": "ledger/profile-snapshots/YYYY/YYYY-MM.jsonl"
        },
        "samples": {
          "type": "string",
          "const": "ledger/samples/<stream>/YYYY/YYYY-MM.jsonl"
        },
        "audit": {
          "type": "string",
          "const": "audit/YYYY/YYYY-MM.jsonl"
        }
      },
      "required": [
        "assessments",
        "events",
        "profileSnapshots",
        "samples",
        "audit"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "vaultId",
    "createdAt",
    "title",
    "timezone",
    "idPolicy",
    "paths",
    "shards"
  ],
  "additionalProperties": false,
  "$id": "@murphai/contracts/vault-metadata.schema.json",
  "title": "Murph Vault Metadata"
}
