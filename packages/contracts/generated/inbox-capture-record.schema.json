{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "murph.inbox-capture.v1"
    },
    "captureId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "identityKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "eventId": {
      "type": "string",
      "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "auditId": {
      "type": "string",
      "pattern": "^aud_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "accountId": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        {
          "type": "null"
        }
      ]
    },
    "externalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "thread": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "title": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            {
              "type": "null"
            }
          ]
        },
        "isDirect": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "isDirect"
      ],
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            {
              "type": "null"
            }
          ]
        },
        "displayName": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            {
              "type": "null"
            }
          ]
        },
        "isSelf": {
          "type": "boolean"
        }
      },
      "required": [
        "isSelf"
      ],
      "additionalProperties": false
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "receivedAt": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "text": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        {
          "type": "null"
        }
      ]
    },
    "raw": {
      "type": "object",
      "properties": {},
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      }
    },
    "sourceDirectory": {
      "type": "string",
      "pattern": "^(?!\\/)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))[A-Za-z0-9._/-]+$"
    },
    "envelopePath": {
      "type": "string",
      "pattern": "^(?!\\/)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))[A-Za-z0-9._/-]+$"
    },
    "rawRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!\\/)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))[A-Za-z0-9._/-]+$"
      },
      "uniqueItems": true
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attachmentId": {
            "type": "string",
            "pattern": "^att_[A-Za-z0-9][A-Za-z0-9_-]*_[0-9]{2}$"
          },
          "ordinal": {
            "type": "integer",
            "minimum": 1
          },
          "externalId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ]
          },
          "kind": {
            "type": "string",
            "enum": [
              "image",
              "audio",
              "video",
              "document",
              "other"
            ]
          },
          "mime": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ]
          },
          "originalPath": {
            "type": "null"
          },
          "fileName": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ]
          },
          "byteSize": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "null"
              }
            ]
          },
          "storedPath": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^(?!\\/)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))[A-Za-z0-9._/-]+$"
              },
              {
                "type": "null"
              }
            ]
          },
          "sha256": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "attachmentId",
          "ordinal",
          "kind"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "captureId",
    "identityKey",
    "eventId",
    "auditId",
    "source",
    "externalId",
    "thread",
    "actor",
    "occurredAt",
    "recordedAt",
    "raw",
    "sourceDirectory",
    "envelopePath",
    "rawRefs",
    "attachments"
  ],
  "additionalProperties": false,
  "$id": "@murph/contracts/inbox-capture-record.schema.json",
  "title": "Murph Inbox Capture Record",
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "properties": {},
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  }
}
