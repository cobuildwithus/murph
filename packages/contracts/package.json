{
  "name": "@healthybob/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "README.md",
    "generated",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./constants": {
      "types": "./dist/src/constants.d.ts",
      "default": "./dist/src/constants.js"
    },
    "./examples": {
      "types": "./dist/src/examples.d.ts",
      "default": "./dist/src/examples.js"
    },
    "./ids": {
      "types": "./dist/src/ids.d.ts",
      "default": "./dist/src/ids.js"
    },
    "./schemas": {
      "types": "./dist/src/schemas.d.ts",
      "default": "./dist/src/schemas.js"
    },
    "./validate": {
      "types": "./dist/src/validate.d.ts",
      "default": "./dist/src/validate.js"
    },
    "./generated/*": "./generated/*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "generate": "pnpm build && node ./dist/scripts/generate-json-schema.js",
    "test": "pnpm build && node ./dist/scripts/verify.js",
    "verify": "pnpm test"
  }
}
