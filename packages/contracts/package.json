{
  "name": "@healthybob/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "generated",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./examples": {
      "types": "./dist/examples.d.ts",
      "default": "./dist/examples.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "default": "./dist/ids.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    },
    "./generated/*": "./generated/*"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json --pretty false && tsc -p tsconfig.scripts.json --pretty false",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "generate": "pnpm build && node ./dist/scripts/generate-json-schema.js",
    "test": "pnpm build && node ./dist/scripts/verify.js",
    "verify": "pnpm test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
