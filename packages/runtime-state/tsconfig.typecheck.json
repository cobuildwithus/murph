{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@murphai/runtime-state": [
        "./src/index.ts"
      ],
      "@murphai/runtime-state/node": [
        "./src/node/index.ts"
      ]
    },
    "rootDir": "../..",
    "composite": false,
    "incremental": true,
    "tsBuildInfoFile": "typecheck.tsbuildinfo"
  },
  "include": [
    "*.ts",
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "dist",
    "coverage"
  ]
}
