{
  "name": "@murphai/assistantd",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "murph-assistantd": "./dist/bin.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -b tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@murphai/assistant-engine": "workspace:*",
    "@murphai/gateway-core": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@murphai/inbox-services": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@murphai/vault-usecases": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
