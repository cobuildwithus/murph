{
  "name": "@murph/assistantd",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "murph-assistantd": "./dist/bin.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -b tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@murph/runtime-state": "workspace:*",
    "murph": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
