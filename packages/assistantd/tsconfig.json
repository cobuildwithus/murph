{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "disableSourceOfProjectReferenceRedirect": true,
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../assistant-engine"
    },
    {
      "path": "../gateway-core"
    },
    {
      "path": "../gateway-local"
    },
    {
      "path": "../runtime-state"
    }
  ],
  "exclude": [
    "dist"
  ]
}
