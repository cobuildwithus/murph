{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": false,
    "baseUrl": "../..",
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@murphai/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@murphai/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@murphai/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@murphai/device-syncd/client": [
        "packages/device-syncd/src/client.ts"
      ],
      "@murphai/device-syncd/*": [
        "packages/device-syncd/src/*.ts"
      ],
      "@murphai/hosted-execution": [
        "packages/hosted-execution/src/index.ts"
      ],
      "@murphai/hosted-execution/*": [
        "packages/hosted-execution/src/*"
      ],
      "@murphai/query": [
        "packages/query/src/index.ts"
      ],
      "@murphai/query/*": [
        "packages/query/src/*"
      ],
      "@murphai/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@murphai/runtime-state/node": [
        "packages/runtime-state/src/node/index.ts"
      ],
      "@murphai/runtime-state/*": [
        "packages/runtime-state/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "sourceMap": false,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
