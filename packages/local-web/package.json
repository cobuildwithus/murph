{
  "name": "@murph/local-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build:app": "pnpm --dir ../.. exec tsx packages/local-web/scripts/next-local.ts build",
    "dev": "pnpm --dir ../.. exec tsx packages/local-web/scripts/next-local.ts dev",
    "build": "pnpm build:app",
    "lint": "eslint .",
    "start": "pnpm --dir ../.. exec tsx packages/local-web/scripts/next-local.ts start",
    "typecheck": "pnpm --dir ../.. exec tsx scripts/ensure-next-route-type-stubs.ts packages/local-web && tsc -p tsconfig.json --pretty false",
    "test": "pnpm --dir ../.. exec vitest run --config packages/local-web/vitest.config.ts --project local-web --no-coverage",
    "verify": "bash scripts/verify-fast.sh"
  },
  "dependencies": {
    "@murph/contracts": "workspace:*",
    "@murph/device-syncd": "workspace:*",
    "@murph/query": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1"
  }
}
