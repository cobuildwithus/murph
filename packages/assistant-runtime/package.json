{
  "name": "@murphai/assistant-runtime",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hosted-assistant-env": {
      "types": "./dist/hosted-assistant-env.d.ts",
      "import": "./dist/hosted-assistant-env.js",
      "default": "./dist/hosted-assistant-env.js"
    },
    "./hosted-email": {
      "types": "./dist/hosted-email.d.ts",
      "import": "./dist/hosted-email.js",
      "default": "./dist/hosted-email.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@murphai/assistant-engine": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/gateway-core": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@murphai/hosted-execution": "workspace:*",
    "@murphai/inbox-services": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@murphai/vault-usecases": "workspace:*"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
