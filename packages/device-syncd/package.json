{
  "name": "@healthybob/device-syncd",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/healthybob"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "healthybob-device-syncd": "./dist/bin.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false"
  },
  "dependencies": {
    "@healthybob/importers": "workspace:*",
    "@healthybob/runtime-state": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
