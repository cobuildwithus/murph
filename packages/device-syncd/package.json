{
  "name": "@murphai/device-syncd",
  "version": "0.1.10",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "murph-device-syncd": "./dist/bin.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./public-ingress": {
      "types": "./dist/public-ingress.d.ts",
      "default": "./dist/public-ingress.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    },
    "./hosted-hints": {
      "types": "./dist/hosted-hints.d.ts",
      "default": "./dist/hosted-hints.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "default": "./dist/http.js"
    },
    "./providers/garmin": {
      "types": "./dist/providers/garmin.d.ts",
      "default": "./dist/providers/garmin.js"
    },
    "./providers/oura": {
      "types": "./dist/providers/oura.d.ts",
      "default": "./dist/providers/oura.js"
    },
    "./providers/whoop": {
      "types": "./dist/providers/whoop.d.ts",
      "default": "./dist/providers/whoop.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "default": "./dist/service.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -b tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage"
  },
  "dependencies": {
    "@murphai/importers": "workspace:*",
    "@murphai/runtime-state": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
