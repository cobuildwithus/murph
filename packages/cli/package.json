{
  "name": "@murphai/murph",
  "version": "0.1.17",
  "private": false,
  "description": "Murph is a personal health assistant you run locally. Install this package to get the murph CLI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "config.schema.json",
    "LICENSE"
  ],
  "keywords": [
    "murph",
    "health",
    "assistant",
    "personal-ai",
    "local-first",
    "cli"
  ],
  "bin": {
    "vault-cli": "dist/bin.js",
    "murph": "dist/bin.js"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.build.json",
    "gen:config-schema": "tsx ./scripts/generate-incur-config-schema.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm --dir ../.. build:test-runtime:prepared && tsx ./scripts/verify-package-shape.ts && MURPH_PREPARED_CLI_RUNTIME_ARTIFACTS=1 pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --no-coverage",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.35",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "0.6.0",
    "@photon-ai/imessage-kit": "2.1.2",
    "@murphai/assistant-cli": "workspace:*",
    "@murphai/assistant-engine": "workspace:*",
    "@murphai/assistantd": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@murphai/hosted-execution": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/query": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@murphai/setup-cli": "workspace:*",
    "ai": "^6.0.116",
    "grammy": "1.41.1",
    "ink": "^6.8.0",
    "incur": "0.3.13",
    "linkedom": "0.18.12",
    "pdfjs-dist": "5.6.205",
    "react": "^19.2.4",
    "zod": "^4.1.8"
  },
  "optionalDependencies": {
    "@murphai/gateway-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "bundleDependencies": [
    "@murphai/assistant-cli",
    "@murphai/assistant-engine",
    "@murphai/assistantd",
    "@murphai/core",
    "@murphai/device-syncd",
    "@murphai/gateway-local",
    "@murphai/importers",
    "@murphai/inboxd",
    "@murphai/messaging-ingress",
    "@murphai/operator-config",
    "@murphai/parsers",
    "@murphai/query",
    "@murphai/runtime-state",
    "@murphai/setup-cli"
  ]
}
