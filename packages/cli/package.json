{
  "name": "murph",
  "version": "0.0.0",
  "private": false,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./inbox-services": {
      "types": "./dist/inbox-services.d.ts",
      "default": "./dist/inbox-services.js"
    },
    "./vault-services": {
      "types": "./dist/vault-services.d.ts",
      "default": "./dist/vault-services.js"
    },
    "./vault-cli-services": {
      "types": "./dist/vault-cli-services.d.ts",
      "default": "./dist/vault-cli-services.js"
    },
    "./assistant-core": {
      "types": "./dist/assistant-core.d.ts",
      "default": "./dist/assistant-core.js"
    },
    "./gateway-core": {
      "types": "./dist/gateway-core.d.ts",
      "default": "./dist/gateway-core.js"
    },
    "./gateway-core-local": {
      "types": "./dist/gateway-core-local.d.ts",
      "default": "./dist/gateway-core-local.js"
    },
    "./assistant/automation": {
      "types": "./dist/assistant/automation.d.ts",
      "default": "./dist/assistant/automation.js"
    },
    "./assistant/cron": {
      "types": "./dist/assistant/cron.d.ts",
      "default": "./dist/assistant/cron.js"
    },
    "./assistant/outbox": {
      "types": "./dist/assistant/outbox.d.ts",
      "default": "./dist/assistant/outbox.js"
    },
    "./assistant/status": {
      "types": "./dist/assistant/status.d.ts",
      "default": "./dist/assistant/status.js"
    },
    "./assistant/store": {
      "types": "./dist/assistant/store.d.ts",
      "default": "./dist/assistant/store.js"
    },
    "./operator-config": {
      "types": "./dist/operator-config.d.ts",
      "default": "./dist/operator-config.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "vault-cli": "dist/bin.js",
    "murph": "dist/bin.js"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm --dir ../contracts build && pnpm --dir ../hosted-execution build && pnpm --dir ../runtime-state build && pnpm --dir ../core build && pnpm --dir ../importers build && pnpm --dir ../device-syncd build && pnpm --dir ../query build && pnpm --dir ../inboxd build && pnpm --dir ../parsers build && pnpm build && tsx ./scripts/verify-package-shape.ts && MURPH_PREPARED_CLI_RUNTIME_ARTIFACTS=1 pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@murph/contracts": "workspace:*",
    "@murph/core": "workspace:*",
    "@murph/device-syncd": "workspace:*",
    "@murph/importers": "workspace:*",
    "@murph/inboxd": "workspace:*",
    "@murph/parsers": "workspace:*",
    "@murph/query": "workspace:*",
    "@murph/runtime-state": "workspace:*",
    "@photon-ai/imessage-kit": "2.1.2",
    "ai": "^6.0.116",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "incur": "0.3.4",
    "react": "^19.2.4",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
