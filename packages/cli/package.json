{
  "name": "@murphai/murph",
  "version": "0.2.6",
  "private": false,
  "description": "Murph is a personal health assistant you run locally. Install this package to get the murph CLI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "config.schema.json",
    "LICENSE"
  ],
  "keywords": [
    "murph",
    "health",
    "assistant",
    "personal-ai",
    "local-first",
    "cli"
  ],
  "bin": {
    "vault-cli": "dist/bin.js",
    "murph": "dist/bin.js"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.build.json --force",
    "gen:config-schema": "tsx ./scripts/generate-incur-config-schema.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm test:source",
    "test:source": "pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --no-coverage",
    "test:coverage": "pnpm test:source:coverage",
    "test:source:coverage": "pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --coverage",
    "verify:prepared-runtime": "pnpm --dir ../.. build:test-runtime:prepared",
    "verify:package-shape": "pnpm build && node --import=tsx ./scripts/verify-package-shape.ts",
    "test:built-runtime": "MURPH_PREPARED_CLI_RUNTIME_ARTIFACTS=1 pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --no-coverage",
    "test:built-runtime:coverage": "MURPH_PREPARED_CLI_RUNTIME_ARTIFACTS=1 pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --coverage",
    "verify": "pnpm verify:prepared-runtime && pnpm verify:package-shape && pnpm test:built-runtime",
    "verify:coverage": "pnpm verify:prepared-runtime && pnpm verify:package-shape && pnpm test:built-runtime:coverage",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.35",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "0.6.0",
    "@murphai/assistant-cli": "workspace:*",
    "@murphai/assistant-engine": "workspace:*",
    "@murphai/assistantd": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@murphai/hosted-execution": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inbox-services": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/operator-config": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/query": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@murphai/setup-cli": "workspace:*",
    "@murphai/vault-usecases": "workspace:*",
    "ai": "^6.0.116",
    "grammy": "1.41.1",
    "ink": "^6.8.0",
    "incur": "0.3.13",
    "linkedom": "0.18.12",
    "pdfjs-dist": "5.6.205",
    "react": "^19.2.4",
    "zod": "^4.1.8"
  },
  "optionalDependencies": {
    "@murphai/gateway-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "bundleDependencies": [
    "@murphai/assistant-cli",
    "@murphai/assistant-engine",
    "@murphai/assistantd",
    "@murphai/core",
    "@murphai/device-syncd",
    "@murphai/gateway-local",
    "@murphai/importers",
    "@murphai/inbox-services",
    "@murphai/inboxd",
    "@murphai/messaging-ingress",
    "@murphai/operator-config",
    "@murphai/parsers",
    "@murphai/query",
    "@murphai/runtime-state",
    "@murphai/setup-cli",
    "@murphai/vault-usecases"
  ]
}
