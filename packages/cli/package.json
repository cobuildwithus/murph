{
  "name": "@murphai/murph",
  "version": "0.1.3",
  "private": false,
  "description": "Murph is a personal health assistant you run locally. Install this package to get the murph CLI.",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assistant/automation": {
      "types": "./dist/assistant/automation.d.ts",
      "default": "./dist/assistant/automation.js"
    },
    "./assistant/cron": {
      "types": "./dist/assistant/cron.d.ts",
      "default": "./dist/assistant/cron.js"
    },
    "./assistant/outbox": {
      "types": "./dist/assistant/outbox.d.ts",
      "default": "./dist/assistant/outbox.js"
    },
    "./assistant/status": {
      "types": "./dist/assistant/status.d.ts",
      "default": "./dist/assistant/status.js"
    },
    "./assistant/store": {
      "types": "./dist/assistant/store.d.ts",
      "default": "./dist/assistant/store.js"
    },
    "./assistant/service": {
      "types": "./dist/assistant/service.d.ts",
      "default": "./dist/assistant/service.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "murph",
    "health",
    "assistant",
    "personal-ai",
    "local-first",
    "cli"
  ],
  "bin": {
    "vault-cli": "dist/bin.js",
    "murph": "dist/bin.js"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist && tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm --dir ../.. build:test-runtime:prepared && tsx ./scripts/verify-package-shape.ts && MURPH_PREPARED_CLI_RUNTIME_ARTIFACTS=1 pnpm --dir ../.. exec vitest run --config packages/cli/vitest.workspace.ts --no-coverage",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@murphai/assistant-core": "workspace:*",
    "@murphai/assistantd": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/parsers": "workspace:*",
    "@murphai/query": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "ink": "^6.8.0",
    "incur": "0.3.13",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@murphai/gateway-core": "workspace:*",
    "@murphai/gateway-local": "workspace:*",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "zod": "^4.1.8"
  }
}
