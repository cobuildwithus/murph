{
  "name": "@murphai/gateway-core",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist .tsbuildinfo && tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "dependencies": {
    "zod": "^4.1.8"
  }
}
