{
  "name": "@murphai/messaging-ingress",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./linq-webhook": {
      "types": "./dist/linq-webhook.d.ts",
      "default": "./dist/linq-webhook.js"
    },
    "./telegram-webhook": {
      "types": "./dist/telegram-webhook.d.ts",
      "default": "./dist/telegram-webhook.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/rm-paths.mjs dist .tsbuildinfo && tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "pnpm exec vitest run --config vitest.config.ts --no-coverage",
    "test:coverage": "pnpm exec vitest run --config vitest.config.ts --coverage"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
