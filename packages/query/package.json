{
  "name": "@murph/query",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "license": "GPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/murph"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js",
      "default": "./dist/search.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "pnpm --dir ../contracts build && pnpm --dir ../.. exec vitest run packages/query/test/query.test.ts packages/query/test/health-tail.test.ts packages/query/test/health-registry-definitions.test.ts --no-coverage"
  },
  "dependencies": {
    "@murph/contracts": "workspace:*",
    "@murph/runtime-state": "workspace:*",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
