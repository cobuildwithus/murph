# Healthy Bob does not auto-load dotenv files.
# If you want to use this file locally, source it explicitly in your shell:
#   set -a; source ./.env; set +a

# Telegram bot integration
HEALTHYBOB_TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=

# Optional Telegram API overrides
# HEALTHYBOB_TELEGRAM_API_BASE_URL=
# HEALTHYBOB_TELEGRAM_FILE_BASE_URL=

# Optional local vault default for shell sessions
# HEALTHYBOB_VAULT=
