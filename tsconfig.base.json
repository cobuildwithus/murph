{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@murphai/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@murphai/contracts/generated/*": [
        "packages/contracts/generated/*"
      ],
      "@murphai/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@murphai/hosted-execution": [
        "packages/hosted-execution/src/index.ts"
      ],
      "@murphai/hosted-execution/*": [
        "packages/hosted-execution/src/*"
      ],
      "@murphai/messaging-ingress": [
        "packages/messaging-ingress/src/index.ts"
      ],
      "@murphai/messaging-ingress/*": [
        "packages/messaging-ingress/src/*"
      ],
      "@murphai/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@murphai/runtime-state/node": [
        "packages/runtime-state/src/node/index.ts"
      ],
      "@murphai/runtime-state/*": [
        "packages/runtime-state/src/*"
      ],
      "@murphai/core": [
        "packages/core/src/index.ts"
      ],
      "@murphai/core/*": [
        "packages/core/src/*"
      ],
      "@murphai/importers": [
        "packages/importers/src/index.ts"
      ],
      "@murphai/importers/*": [
        "packages/importers/src/*"
      ],
      "@murphai/query": [
        "packages/query/src/index.ts"
      ],
      "@murphai/query/*": [
        "packages/query/src/*"
      ],
      "@murphai/inboxd": [
        "packages/inboxd/src/index.ts"
      ],
      "@murphai/inboxd/connectors/email/normalize-parsed": [
        "packages/inboxd/src/connectors/email/normalize-parsed.ts"
      ],
      "@murphai/inboxd/connectors/email/parsed": [
        "packages/inboxd/src/connectors/email/parsed.ts"
      ],
      "@murphai/inboxd/*": [
        "packages/inboxd/src/*"
      ],
      "@murphai/parsers": [
        "packages/parsers/src/index.ts"
      ],
      "@murphai/parsers/*": [
        "packages/parsers/src/*"
      ],
      "@murphai/assistant-runtime": [
        "packages/assistant-runtime/src/index.ts"
      ],
      "@murphai/assistant-runtime/*": [
        "packages/assistant-runtime/src/*"
      ],
      "@murphai/assistantd": [
        "packages/assistantd/src/index.ts"
      ],
      "@murphai/assistantd/client": [
        "packages/assistantd/src/client.ts"
      ],
      "@murphai/assistantd/*": [
        "packages/assistantd/src/*"
      ],
      "@murphai/assistant-core": [
        "packages/assistant-core/src/index.ts"
      ],
      "@murphai/assistant-core/*": [
        "packages/assistant-core/src/*.ts"
      ],
      "@murphai/gateway-core": [
        "packages/gateway-core/src/index.ts"
      ],
      "@murphai/gateway-local": [
        "packages/gateway-local/src/index.ts"
      ],
      "murph": [
        "packages/cli/src/index.ts"
      ],
      "murph/assistant/automation": [
        "packages/cli/src/assistant/automation.ts"
      ],
      "murph/assistant/cron": [
        "packages/cli/src/assistant/cron.ts"
      ],
      "murph/assistant/service": [
        "packages/cli/src/assistant/service.ts"
      ],
      "murph/assistant/outbox": [
        "packages/cli/src/assistant/outbox.ts"
      ],
      "murph/assistant/status": [
        "packages/cli/src/assistant/status.ts"
      ],
      "murph/assistant/store": [
        "packages/cli/src/assistant/store.ts"
      ],
      "@murphai/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@murphai/device-syncd/client": [
        "packages/device-syncd/src/client.ts"
      ],
      "@murphai/device-syncd/*": [
        "packages/device-syncd/src/*.ts"
      ]
    },
    "types": [
      "node"
    ],
    "rewriteRelativeImportExtensions": true
  }
}
