{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@healthybob/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@healthybob/contracts/generated/*": [
        "packages/contracts/generated/*"
      ],
      "@healthybob/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@healthybob/hosted-execution": [
        "packages/hosted-execution/src/index.ts"
      ],
      "@healthybob/hosted-execution/*": [
        "packages/hosted-execution/src/*"
      ],
      "@healthybob/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@healthybob/runtime-state/*": [
        "packages/runtime-state/src/*"
      ],
      "@healthybob/core": [
        "packages/core/src/index.ts"
      ],
      "@healthybob/core/*": [
        "packages/core/src/*"
      ],
      "@healthybob/importers": [
        "packages/importers/src/index.ts"
      ],
      "@healthybob/importers/*": [
        "packages/importers/src/*"
      ],
      "@healthybob/query": [
        "packages/query/src/index.ts"
      ],
      "@healthybob/query/*": [
        "packages/query/src/*"
      ],
      "@healthybob/inboxd": [
        "packages/inboxd/src/index.ts"
      ],
      "@healthybob/inboxd/connectors/email/normalize-parsed": [
        "packages/inboxd/src/connectors/email/normalize-parsed.ts"
      ],
      "@healthybob/inboxd/connectors/email/parsed": [
        "packages/inboxd/src/connectors/email/parsed.ts"
      ],
      "@healthybob/inboxd/*": [
        "packages/inboxd/src/*"
      ],
      "@healthybob/parsers": [
        "packages/parsers/src/index.ts"
      ],
      "@healthybob/parsers/*": [
        "packages/parsers/src/*"
      ],
      "@healthybob/assistant-runtime": [
        "packages/assistant-runtime/src/index.ts"
      ],
      "@healthybob/assistant-runtime/*": [
        "packages/assistant-runtime/src/*"
      ],
      "healthybob": [
        "packages/cli/src/index.ts"
      ],
      "healthybob/inbox-services": [
        "packages/cli/src/inbox-services.ts"
      ],
      "healthybob/vault-cli-services": [
        "packages/cli/src/vault-cli-services.ts"
      ],
      "healthybob/assistant/automation": [
        "packages/cli/src/assistant/automation.ts"
      ],
      "healthybob/assistant/cron": [
        "packages/cli/src/assistant/cron.ts"
      ],
      "healthybob/assistant/outbox": [
        "packages/cli/src/assistant/outbox.ts"
      ],
      "healthybob/assistant/status": [
        "packages/cli/src/assistant/status.ts"
      ],
      "healthybob/assistant/store": [
        "packages/cli/src/assistant/store.ts"
      ],
      "healthybob/*": [
        "packages/cli/src/*"
      ],
      "@healthybob/cli": [
        "packages/cli/src/index.ts"
      ],
      "@healthybob/cli/*": [
        "packages/cli/src/*"
      ],
      "@healthybob/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@healthybob/device-syncd/*": [
        "packages/device-syncd/src/*"
      ],
      "@healthybob/assistant-services": [
        "packages/assistant-services/src/index.ts"
      ],
      "@healthybob/assistant-services/*": [
        "packages/assistant-services/src/*"
      ]
    },
    "types": [
      "node"
    ],
    "rewriteRelativeImportExtensions": true
  }
}
