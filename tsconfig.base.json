{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@murph/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@murph/contracts/generated/*": [
        "packages/contracts/generated/*"
      ],
      "@murph/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@murph/hosted-execution": [
        "packages/hosted-execution/src/index.ts"
      ],
      "@murph/hosted-execution/*": [
        "packages/hosted-execution/src/*"
      ],
      "@murph/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@murph/runtime-state/*": [
        "packages/runtime-state/src/*"
      ],
      "@murph/core": [
        "packages/core/src/index.ts"
      ],
      "@murph/core/*": [
        "packages/core/src/*"
      ],
      "@murph/importers": [
        "packages/importers/src/index.ts"
      ],
      "@murph/importers/*": [
        "packages/importers/src/*"
      ],
      "@murph/query": [
        "packages/query/src/index.ts"
      ],
      "@murph/query/*": [
        "packages/query/src/*"
      ],
      "@murph/inboxd": [
        "packages/inboxd/src/index.ts"
      ],
      "@murph/inboxd/connectors/email/normalize-parsed": [
        "packages/inboxd/src/connectors/email/normalize-parsed.ts"
      ],
      "@murph/inboxd/connectors/email/parsed": [
        "packages/inboxd/src/connectors/email/parsed.ts"
      ],
      "@murph/inboxd/*": [
        "packages/inboxd/src/*"
      ],
      "@murph/parsers": [
        "packages/parsers/src/index.ts"
      ],
      "@murph/parsers/*": [
        "packages/parsers/src/*"
      ],
      "@murph/assistant-runtime": [
        "packages/assistant-runtime/src/index.ts"
      ],
      "@murph/assistant-runtime/*": [
        "packages/assistant-runtime/src/*"
      ],
      "@murph/assistantd": [
        "packages/assistantd/src/index.ts"
      ],
      "@murph/assistantd/*": [
        "packages/assistantd/src/*"
      ],
      "murph": [
        "packages/cli/src/index.ts"
      ],
      "murph/assistant-core": [
        "packages/cli/src/assistant-core.ts"
      ],
      "murph/inbox-services": [
        "packages/cli/src/inbox-services.ts"
      ],
      "murph/vault-cli-services": [
        "packages/cli/src/vault-cli-services.ts"
      ],
      "murph/assistant/automation": [
        "packages/cli/src/assistant/automation.ts"
      ],
      "murph/assistant/cron": [
        "packages/cli/src/assistant/cron.ts"
      ],
      "murph/assistant/outbox": [
        "packages/cli/src/assistant/outbox.ts"
      ],
      "murph/assistant/status": [
        "packages/cli/src/assistant/status.ts"
      ],
      "murph/assistant/store": [
        "packages/cli/src/assistant/store.ts"
      ],
      "murph/operator-config": [
        "packages/cli/src/operator-config.ts"
      ],
      "@murph/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@murph/device-syncd/*": [
        "packages/device-syncd/src/*"
      ],
      "@murph/assistant-services": [
        "packages/assistant-services/src/index.ts"
      ],
      "@murph/assistant-services/automation": [
        "packages/assistant-services/src/automation.ts"
      ],
      "@murph/assistant-services/cron": [
        "packages/assistant-services/src/cron.ts"
      ],
      "@murph/assistant-services/inbox-services": [
        "packages/assistant-services/src/inbox-services.ts"
      ],
      "@murph/assistant-services/operator-config": [
        "packages/assistant-services/src/operator-config.ts"
      ],
      "@murph/assistant-services/outbox": [
        "packages/assistant-services/src/outbox.ts"
      ],
      "@murph/assistant-services/status": [
        "packages/assistant-services/src/status.ts"
      ],
      "@murph/assistant-services/store": [
        "packages/assistant-services/src/store.ts"
      ],
      "@murph/assistant-services/vault-services": [
        "packages/assistant-services/src/vault-services.ts"
      ],
      "@murph/assistant-services/*": [
        "packages/assistant-services/src/*"
      ]
    },
    "types": [
      "node"
    ],
    "rewriteRelativeImportExtensions": true
  }
}
