{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@murphai/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@murphai/contracts/generated/*": [
        "packages/contracts/generated/*"
      ],
      "@murphai/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@murphai/hosted-execution": [
        "packages/hosted-execution/src/index.ts"
      ],
      "@murphai/hosted-execution/*": [
        "packages/hosted-execution/src/*"
      ],
      "@murphai/cloudflare-hosted-control": [
        "packages/cloudflare-hosted-control/src/index.ts"
      ],
      "@murphai/cloudflare-hosted-control/*": [
        "packages/cloudflare-hosted-control/src/*"
      ],
      "@murphai/messaging-ingress": [
        "packages/messaging-ingress/src/index.ts"
      ],
      "@murphai/messaging-ingress/linq-webhook": [
        "packages/messaging-ingress/src/linq-webhook.ts"
      ],
      "@murphai/messaging-ingress/telegram-webhook": [
        "packages/messaging-ingress/src/telegram-webhook.ts"
      ],
      "@murphai/messaging-ingress/*": [
        "packages/messaging-ingress/src/*"
      ],
      "@murphai/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@murphai/runtime-state/node": [
        "packages/runtime-state/src/node/index.ts"
      ],
      "@murphai/runtime-state/*": [
        "packages/runtime-state/src/*"
      ],
      "@murphai/core": [
        "packages/core/src/index.ts"
      ],
      "@murphai/core/*": [
        "packages/core/src/*"
      ],
      "@murphai/importers": [
        "packages/importers/src/index.ts"
      ],
      "@murphai/importers/*": [
        "packages/importers/src/*"
      ],
      "@murphai/query": [
        "packages/query/src/index.ts"
      ],
      "@murphai/query/*": [
        "packages/query/src/*"
      ],
      "@murphai/inboxd": [
        "packages/inboxd/src/index.ts"
      ],
      "@murphai/inboxd-imessage": [
        "packages/inboxd-imessage/src/index.ts"
      ],
      "@murphai/inboxd/connectors/email/normalize-parsed": [
        "packages/inboxd/src/connectors/email/normalize-parsed.ts"
      ],
      "@murphai/inboxd/connectors/email/parsed": [
        "packages/inboxd/src/connectors/email/parsed.ts"
      ],
      "@murphai/inboxd/runtime": [
        "packages/inboxd/src/runtime.ts"
      ],
      "@murphai/inboxd/*": [
        "packages/inboxd/src/*"
      ],
      "@murphai/parsers": [
        "packages/parsers/src/index.ts"
      ],
      "@murphai/parsers/*": [
        "packages/parsers/src/*"
      ],
      "@murphai/assistant-cli": [
        "packages/assistant-cli/src/index.ts"
      ],
      "@murphai/assistant-cli/assistant/*": [
        "packages/assistant-cli/src/assistant/*.ts"
      ],
      "@murphai/assistant-cli/*": [
        "packages/assistant-cli/src/*"
      ],
      "@murphai/setup-cli": [
        "packages/setup-cli/src/index.ts"
      ],
      "@murphai/setup-cli/*": [
        "packages/setup-cli/src/*"
      ],
      "@murphai/assistant-runtime": [
        "packages/assistant-runtime/src/index.ts"
      ],
      "@murphai/assistant-runtime/*": [
        "packages/assistant-runtime/src/*"
      ],
      "@murphai/assistantd": [
        "packages/assistantd/src/index.ts"
      ],
      "@murphai/assistantd/client": [
        "packages/assistantd/src/client.ts"
      ],
      "@murphai/assistantd/*": [
        "packages/assistantd/src/*"
      ],
      "@murphai/operator-config": [
        "packages/operator-config/src/index.ts"
      ],
      "@murphai/operator-config/*": [
        "packages/operator-config/src/*"
      ],
      "@murphai/assistant-engine": [
        "packages/assistant-engine/src/index.ts"
      ],
      "@murphai/assistant-engine/assistant-cli-access": [
        "packages/assistant-engine/src/assistant-cli-access.ts"
      ],
      "@murphai/assistant-engine/assistant-cli-tools": [
        "packages/assistant-engine/src/assistant-cli-tools.ts"
      ],
      "@murphai/assistant-engine/assistant/*": [
        "packages/assistant-engine/src/assistant/*.ts"
      ],
      "@murphai/assistant-engine/*": [
        "packages/assistant-engine/src/*"
      ],
      "@murphai/inbox-services/testing": [
        "packages/inbox-services/src/testing.ts"
      ],
      "@murphai/vault-usecases": [
        "packages/vault-usecases/src/index.ts"
      ],
      "@murphai/vault-usecases/testing": [
        "packages/vault-usecases/src/testing.ts"
      ],
      "@murphai/vault-usecases/*": [
        "packages/vault-usecases/src/*"
      ],
      "@murphai/gateway-core": [
        "packages/gateway-core/src/index.ts"
      ],
      "@murphai/gateway-local": [
        "packages/gateway-local/src/index.ts"
      ],
      "murph": [
        "packages/cli/src/index.ts"
      ],
      "@murphai/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@murphai/device-syncd/client": [
        "packages/device-syncd/src/client.ts"
      ],
      "@murphai/device-syncd/hosted-runtime": [
        "packages/device-syncd/src/hosted-runtime.ts"
      ],
      "@murphai/device-syncd/*": [
        "packages/device-syncd/src/*.ts"
      ]
    },
    "types": [
      "node"
    ],
    "rewriteRelativeImportExtensions": true
  }
}
