# Copy this file to an untracked local `.env` for development or load the values from your deploy secret manager.
# Keep every value below as a placeholder until you replace it with live credentials; never commit a real hosted `.env`.
# If a live hosted `.env` or deploy secret is exposed, rotate the database credential, provider client secrets,
# webhook verification token, and the hosted device-sync encryption key.
# `DEVICE_SYNC_ENCRYPTION_KEY_VERSION` is metadata only in the current implementation: rotating the key requires
# re-encrypting existing `device_connection_secret` rows before cutover or deliberately invalidating/reconnecting them.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/healthybob_device_sync"
DEVICE_SYNC_ENCRYPTION_KEY="replace-with-32-byte-base64url-key"
DEVICE_SYNC_ENCRYPTION_KEY_VERSION="v1"
DEVICE_SYNC_PUBLIC_BASE_URL="https://your-app.vercel.app/api/device-sync"
DEVICE_SYNC_ALLOWED_MUTATION_ORIGINS="https://your-app.vercel.app,http://localhost:3000"
DEVICE_SYNC_ALLOWED_RETURN_ORIGINS="https://your-app.vercel.app,http://localhost:3000"
DEVICE_SYNC_TRUSTED_USER_ID_HEADER="x-healthybob-user-id"
DEVICE_SYNC_TRUSTED_USER_EMAIL_HEADER="x-healthybob-user-email"
DEVICE_SYNC_TRUSTED_USER_NAME_HEADER="x-healthybob-user-name"
DEVICE_SYNC_TRUSTED_USER_SIGNATURE_HEADER="x-healthybob-user-signature"
DEVICE_SYNC_TRUSTED_USER_SIGNING_SECRET="replace-with-shared-signing-secret"
DEVICE_SYNC_DEV_USER_ID="dev-user"
DEVICE_SYNC_DEV_USER_EMAIL="dev@example.com"
DEVICE_SYNC_DEV_USER_NAME="Dev User"
WHOOP_CLIENT_ID="replace-me"
WHOOP_CLIENT_SECRET="replace-me"
OURA_CLIENT_ID="replace-me"
OURA_CLIENT_SECRET="replace-me"
OURA_WEBHOOK_VERIFICATION_TOKEN="replace-me"
