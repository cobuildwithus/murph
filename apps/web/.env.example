# Copy this file to an untracked local `.env` for development or load the values from your deploy secret manager.
# Keep every value below as a placeholder until you replace it with live credentials; never commit a real hosted `.env`.
# If a live hosted `.env` or deploy secret is exposed, rotate the database credential, provider client secrets,
# webhook verification token, and the hosted device-sync encryption key.
# `DEVICE_SYNC_ENCRYPTION_KEY_VERSION` is metadata only in the current implementation: rotating the key requires
# re-encrypting existing `device_connection_secret` rows before cutover or deliberately invalidating/reconnecting them.
# Use a stable project or custom domain for DEVICE_SYNC_PUBLIC_BASE_URL, not a preview deployment URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/murph_device_sync"
DEVICE_SYNC_ENCRYPTION_KEY="replace-with-32-byte-base64url-key"
DEVICE_SYNC_ENCRYPTION_KEY_VERSION="v1"
DEVICE_SYNC_PUBLIC_BASE_URL="https://your-project.vercel.app/api/device-sync"
DEVICE_SYNC_ALLOWED_MUTATION_ORIGINS="https://your-project.vercel.app,http://localhost:3000"
DEVICE_SYNC_ALLOWED_RETURN_ORIGINS="https://your-project.vercel.app,http://localhost:3000"
DEVICE_SYNC_TRUSTED_USER_ASSERTION_HEADER="x-hosted-user-assertion"
DEVICE_SYNC_TRUSTED_USER_SIGNATURE_HEADER="x-hosted-user-signature"
DEVICE_SYNC_TRUSTED_USER_SIGNING_SECRET="replace-with-shared-signing-secret"
# Trusted auth middleware/proxy must mint a fresh signed assertion per request.
# Assertions should be short-lived (<= 5 minutes), bound to audience/method/path/origin,
# and carry a strong random nonce because the hosted control plane consumes each nonce once.
DEVICE_SYNC_DEV_USER_ID="dev-user"
DEVICE_SYNC_DEV_USER_EMAIL="dev@example.com"
DEVICE_SYNC_DEV_USER_NAME="Dev User"
GARMIN_CLIENT_ID="replace-me"
GARMIN_CLIENT_SECRET="replace-me"
WHOOP_CLIENT_ID="replace-me"
WHOOP_CLIENT_SECRET="replace-me"
OURA_CLIENT_ID="replace-me"
OURA_CLIENT_SECRET="replace-me"
OURA_WEBHOOK_VERIFICATION_TOKEN="replace-me"

LINQ_WEBHOOK_SECRET="replace-me"

# Hosted onboarding / Privy phone auth / billing / Linq SMS handoff
HOSTED_ONBOARDING_PUBLIC_BASE_URL="https://your-app.vercel.app"
HOSTED_ONBOARDING_SIGNUP_PHONE_NUMBER="+1 555 010 1234"
NEXT_PUBLIC_PRIVY_APP_ID="cm_app_replace_me"
NEXT_PUBLIC_PRIVY_CLIENT_ID="client_replace_me"
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----"
# In the Privy dashboard:
# - restrict allowed domains to your real hosted origins and remove stale test/dev domains
# - enable email login/linking so /settings can verify user email addresses
# - enable identity tokens at User management > Authentication > Advanced
# - enable access + identity tokens for the hosted web client so browser requests can authenticate with bearer + identity-token headers
# - keep Privy app-client session duration aligned with your desired risk window
# - if you use separate localhost and production web app clients, set NEXT_PUBLIC_PRIVY_CLIENT_ID per environment
# Optional: if you set a Privy base domain for other web clients, also set PRIVY_BASE_DOMAIN so apps/web CSP can allow the
# domain-specific Privy instance (for example: example.com -> https://privy.example.com).
PRIVY_BASE_DOMAIN="example.com"
HOSTED_ONBOARDING_INVITE_TTL_HOURS="168"
HOSTED_ONBOARDING_SESSION_TTL_DAYS="30"
HOSTED_ONBOARDING_SESSION_COOKIE_NAME="hosted_session"
HOSTED_ONBOARDING_STRIPE_BILLING_MODE="payment"
HOSTED_ONBOARDING_STRIPE_PRICE_ID="price_replace_me"
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
# Optional: enable inline RevNet issuance after successful Stripe subscription invoices.
# This native-ETH MVP expects subscription billing mode, a pre-funded treasury wallet on the target chain,
# and an operator-managed wei-per-Stripe-minor-unit pricing knob.
HOSTED_ONBOARDING_REVNET_CHAIN_ID="8453"
HOSTED_ONBOARDING_REVNET_PROJECT_ID="1"
HOSTED_ONBOARDING_REVNET_RPC_URL="https://mainnet.base.org"
HOSTED_ONBOARDING_REVNET_TERMINAL_ADDRESS="0xreplace_me"
HOSTED_ONBOARDING_REVNET_STRIPE_CURRENCY="usd"
HOSTED_ONBOARDING_REVNET_TREASURY_PRIVATE_KEY="0xreplace_me"
HOSTED_ONBOARDING_REVNET_WEI_PER_STRIPE_MINOR_UNIT="replace_with_integer_wei_rate"
LINQ_API_TOKEN="replace-me"
LINQ_API_BASE_URL="https://api.linqapp.com/api/partner/v3"
HOSTED_EXECUTION_DISPATCH_URL="https://your-cloudflare-worker.example.com"
# Must match the Cloudflare worker's HOSTED_EXECUTION_SIGNING_SECRET so dispatch signatures verify.
HOSTED_EXECUTION_SIGNING_SECRET="replace-with-shared-signing-secret"
HOSTED_EXECUTION_DISPATCH_TIMEOUT_MS="30000"
# Must match the Cloudflare worker's HOSTED_EXECUTION_CONTROL_TOKEN so hosted web can trigger operator/internal runs.
HOSTED_EXECUTION_CONTROL_TOKEN="replace-with-operator-control-token"
# Must match the Cloudflare runner's HOSTED_EXECUTION_INTERNAL_TOKEN so runner callbacks can reach hosted web internal routes.
HOSTED_EXECUTION_INTERNAL_TOKEN="replace-with-web-internal-bearer-token"
# Optional: persist provider/session/request debug fields for hosted AI usage rows.
# Leave unset for the privacy-first default that stores billing-safe usage counters only.
HOSTED_AI_USAGE_PERSIST_DEBUG_FIELDS="false"
# Vercel automatically sends Authorization: Bearer <CRON_SECRET> when invoking configured cron routes.
CRON_SECRET="replace-with-vercel-cron-bearer-token"
