{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": false,
    "baseUrl": "../..",
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "apps/web/*"
      ],
      "@healthybob/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@healthybob/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@healthybob/runtime-state": [
        "packages/runtime-state/src/index.ts"
      ],
      "@healthybob/runtime-state/*": [
        "packages/runtime-state/src/*"
      ],
      "@healthybob/core": [
        "packages/core/src/index.ts"
      ],
      "@healthybob/core/*": [
        "packages/core/src/*"
      ],
      "@healthybob/importers": [
        "packages/importers/src/index.ts"
      ],
      "@healthybob/importers/*": [
        "packages/importers/src/*"
      ],
      "@healthybob/inboxd": [
        "packages/inboxd/src/index.ts"
      ],
      "@healthybob/inboxd/*": [
        "packages/inboxd/src/*"
      ],
      "@healthybob/device-syncd": [
        "packages/device-syncd/src/index.ts"
      ],
      "@healthybob/device-syncd/*": [
        "packages/device-syncd/src/*"
      ]
    },
    "sourceMap": false,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
