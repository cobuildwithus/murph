{
  "name": "@murph/hosted-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "dev:smoke": "pnpm --dir ../.. exec tsx apps/web/scripts/dev-smoke.ts",
    "typecheck": "prisma generate && tsc -p tsconfig.json --pretty false",
    "test": "pnpm typecheck && pnpm --dir ../.. exec vitest run --config apps/web/vitest.config.ts --no-coverage --maxWorkers 1 && pnpm dev:smoke && pnpm build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@cobuild/wire": "^0.3.6",
    "@murph/contracts": "workspace:*",
    "@murph/core": "workspace:*",
    "@murph/device-syncd": "workspace:*",
    "@murph/hosted-execution": "workspace:*",
    "@murph/importers": "workspace:*",
    "@murph/inboxd": "workspace:*",
    "@murph/runtime-state": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@privy-io/node": "^0.11.0",
    "@privy-io/react-auth": "^3.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "next": "^16.2.1",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "viem": "^2.38.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.6.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1"
  }
}
