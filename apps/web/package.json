{
  "name": "@healthybob/hosted-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "ensure:device-syncd": "pnpm --dir ../../packages/device-syncd build",
    "dev": "pnpm ensure:device-syncd && next dev --webpack",
    "build": "pnpm ensure:device-syncd && prisma generate && next build --webpack",
    "start": "next start",
    "typecheck": "pnpm ensure:device-syncd && prisma generate && tsc -p tsconfig.json --pretty false",
    "test": "pnpm ensure:device-syncd && pnpm typecheck && pnpm --dir ../.. exec vitest run --config apps/web/vitest.config.ts --no-coverage --maxWorkers 1 && pnpm build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@healthybob/contracts": "workspace:*",
    "@healthybob/core": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@healthybob/device-syncd": "workspace:*",
    "@healthybob/importers": "workspace:*",
    "@healthybob/runtime-state": "workspace:*",
    "@prisma/client": "^7.5.0",
    "next": "^16.1.6",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.6.1",
    "prisma": "^7.5.0"
  }
}
