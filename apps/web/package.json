{
  "name": "@murphai/hosted-web",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "pnpm --dir ../.. exec tsx apps/web/scripts/dev-local.ts",
    "dev:turbopack": "pnpm --dir ../.. exec tsx apps/web/scripts/dev-local.ts --turbopack",
    "build": "prisma generate && next build",
    "lint": "eslint .",
    "start": "next start",
    "dev:smoke": "pnpm --dir ../.. exec tsx apps/web/scripts/dev-smoke.ts",
    "typecheck": "pnpm --dir ../.. exec tsx scripts/ensure-next-route-type-stubs.ts apps/web && prisma generate && tsc -p tsconfig.json --pretty false",
    "typecheck:prepared": "pnpm --dir ../.. exec tsx scripts/ensure-next-route-type-stubs.ts apps/web && tsc -p tsconfig.json --pretty false",
    "test": "pnpm --dir ../.. exec vitest run --config apps/web/vitest.workspace.ts --no-coverage",
    "contact-privacy:backfill": "pnpm --dir ../.. exec tsx apps/web/scripts/backfill-hosted-contact-privacy.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "verify": "bash scripts/verify-fast.sh"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@cobuild/wire": "^0.3.6",
    "@murphai/cloudflare-hosted-control": "workspace:*",
    "@murphai/contracts": "workspace:*",
    "@murphai/core": "workspace:*",
    "@murphai/device-syncd": "workspace:*",
    "@murphai/hosted-execution": "workspace:*",
    "@murphai/importers": "workspace:*",
    "@murphai/inboxd": "workspace:*",
    "@murphai/messaging-ingress": "workspace:*",
    "@murphai/runtime-state": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@privy-io/node": "^0.11.0",
    "@privy-io/react-auth": "^3.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@vercel/oidc": "^3.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "next": "^16.2.1",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "4.1.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "viem": "^2.38.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1"
  }
}
