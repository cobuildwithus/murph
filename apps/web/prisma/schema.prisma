generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DeviceConnection {
  id                       String             @id
  userId                   String             @map("user_id")
  provider                 String
  providerAccountBlindIndex String            @map("provider_account_blind_index")
  status                   String             @default("active")
  connectedAt              DateTime           @map("connected_at")
  lastWebhookAt            DateTime?          @map("last_webhook_at")
  lastSyncStartedAt        DateTime?          @map("last_sync_started_at")
  lastSyncCompletedAt      DateTime?          @map("last_sync_completed_at")
  lastSyncErrorAt          DateTime?          @map("last_sync_error_at")
  lastErrorCode            String?            @map("last_error_code")
  lastErrorMessage         String?            @map("last_error_message")
  nextReconcileAt          DateTime?          @map("next_reconcile_at")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  signals                  DeviceSyncSignal[]
  tokenAudits              DeviceTokenAudit[]

  @@unique([provider, providerAccountBlindIndex])
  @@index([userId, provider])
  @@map("device_connection")
}

model DeviceTokenAudit {
  id                   Int              @id @default(autoincrement())
  userId               String           @map("user_id")
  connectionId         String           @map("connection_id")
  provider             String
  action               String
  channel              String
  sessionId            String?          @map("session_id")
  tokenVersion         Int              @map("token_version")
  keyVersion           String           @map("key_version")
  expectedTokenVersion Int?             @map("expected_token_version")
  forceRefresh         Boolean?         @map("force_refresh")
  refreshOutcome       String?          @map("refresh_outcome")
  tokenVersionChanged  Boolean?         @map("token_version_changed")
  createdAt            DateTime         @default(now()) @map("created_at")
  connection           DeviceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, id])
  @@index([connectionId, createdAt])
  @@index([createdAt])
  @@map("device_token_audit")
}

model DeviceOauthSession {
  state        String   @id
  userId       String?  @map("user_id")
  provider     String
  returnTo     String?  @map("return_to")
  createdAt    DateTime @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([expiresAt])
  @@index([userId, provider])
  @@map("device_oauth_session")
}

model DeviceWebhookTrace {
  provider                 String
  traceId                  String    @map("trace_id")
  providerAccountBlindIndex String   @map("provider_account_blind_index")
  eventType                String    @map("event_type")
  status                   String    @default("processed")
  processingExpiresAt      DateTime? @map("processing_expires_at")
  receivedAt               DateTime  @map("received_at")
  createdAt                DateTime  @default(now()) @map("created_at")

  @@id([provider, traceId])
  @@index([provider, providerAccountBlindIndex])
  @@index([receivedAt])
  @@map("device_webhook_trace")
}

model DeviceSyncSignal {
  id                   Int               @id @default(autoincrement())
  userId               String            @map("user_id")
  connectionId         String?           @map("connection_id")
  provider             String
  kind                 String
  occurredAt           DateTime?         @map("occurred_at")
  traceId              String?           @map("trace_id")
  eventType            String?           @map("event_type")
  resourceCategory     String?           @map("resource_category")
  reason               String?           @map("reason")
  nextReconcileAt      DateTime?         @map("next_reconcile_at")
  revokeWarningCode    String?           @map("revoke_warning_code")
  revokeWarningMessage String?           @map("revoke_warning_message")
  createdAt            DateTime          @default(now()) @map("created_at")
  connection           DeviceConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, id])
  @@index([connectionId])
  @@map("device_sync_signal")
}

model DeviceAgentSession {
  id                  String    @id
  userId              String    @map("user_id")
  label               String?
  tokenHash           String    @unique @map("token_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  expiresAt           DateTime  @map("expires_at")
  lastSeenAt          DateTime? @map("last_seen_at")
  revokedAt           DateTime? @map("revoked_at")
  revokeReason        String?   @map("revoke_reason")
  replacedBySessionId String?   @map("replaced_by_session_id")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([replacedBySessionId])
  @@map("device_agent_session")
}

model DeviceBrowserAssertionNonce {
  nonceHash String   @id @map("nonce_hash")
  userId    String   @map("user_id")
  method    String
  path      String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("device_browser_assertion_nonce")
}

model HostedWebInternalRequestNonce {
  nonceHash String   @id @map("nonce_hash")
  userId    String   @map("user_id")
  method    String
  path      String
  search    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("hosted_web_internal_request_nonce")
}

enum HostedBillingStatus {
  not_started
  active
  incomplete
  past_due
  canceled
  unpaid
  paused
}

enum HostedStripeEventStatus {
  pending
  processing
  completed
  failed
  poisoned
}

enum HostedRevnetIssuanceStatus {
  pending
  submitting
  submitted
  confirmed
  failed
}

enum ExecutionOutboxStatus {
  queued
  dispatching
  dispatched
  delivery_failed
}

enum HostedWebhookReceiptStatus {
  processing
  completed
  failed
}

enum HostedWebhookReceiptSideEffectKind {
  hosted_execution_dispatch
  linq_message_send
  revnet_invoice_issue
}

enum HostedWebhookReceiptSideEffectStatus {
  pending
  sent_unconfirmed
}

model HostedMember {
  id              String                  @id
  billingStatus   HostedBillingStatus     @default(not_started) @map("billing_status")
  suspendedAt     DateTime?               @map("suspended_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  invites         HostedInvite[]
  revnetIssuances HostedRevnetIssuance[]
  aiUsage         HostedAiUsage[]
  linqDailyStates HostedLinqDailyState[]
  identity        HostedMemberIdentity?
  routing         HostedMemberRouting?
  billingRef      HostedMemberBillingRef?

  @@index([billingStatus])
  @@map("hosted_member")
}

model HostedMemberIdentity {
  memberId                       String       @unique @map("member_id")
  maskedPhoneNumberHint          String       @map("masked_phone_number_hint")
  phoneLookupKey                 String       @unique @map("phone_lookup_key")
  phoneNumberEncrypted           String?      @map("phone_number_encrypted")
  phoneNumberVerifiedAt          DateTime?    @map("phone_number_verified_at")
  privyUserLookupKey             String?      @unique @map("privy_user_lookup_key")
  privyUserIdEncrypted           String?      @map("privy_user_id_encrypted")
  walletAddressLookupKey         String?      @unique @map("wallet_address_lookup_key")
  walletAddressEncrypted         String?      @map("wallet_address_encrypted")
  walletChainType                String?      @map("wallet_chain_type")
  walletProvider                 String?      @map("wallet_provider")
  walletCreatedAt                DateTime?    @map("wallet_created_at")
  signupPhoneNumberEncrypted     String?      @map("signup_phone_number_encrypted")
  signupPhoneCodeSentAt          DateTime?    @map("signup_phone_code_sent_at")
  signupPhoneCodeSendAttemptId   String?      @map("signup_phone_code_send_attempt_id")
  signupPhoneCodeSendAttemptStartedAt DateTime? @map("signup_phone_code_send_attempt_started_at")
  createdAt                      DateTime     @default(now()) @map("created_at")
  updatedAt                      DateTime     @updatedAt @map("updated_at")
  member                         HostedMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("hosted_member_identity")
}

model HostedMemberRouting {
  memberId                       String       @unique @map("member_id")
  /// Sticky post-activation Linq home thread for the member's long-lived Murph number.
  linqChatLookupKey              String?      @unique @map("linq_chat_lookup_key")
  linqChatIdEncrypted            String?      @map("linq_chat_id_encrypted")
  linqRecipientPhoneLookupKey    String?      @map("linq_recipient_phone_lookup_key")
  linqRecipientPhoneEncrypted    String?      @map("linq_recipient_phone_encrypted")
  /// Pre-activation Linq acquisition/referral thread before a home line is chosen.
  pendingLinqChatLookupKey       String?      @unique @map("pending_linq_chat_lookup_key")
  pendingLinqChatIdEncrypted     String?      @map("pending_linq_chat_id_encrypted")
  pendingLinqRecipientPhoneLookupKey String?  @map("pending_linq_recipient_phone_lookup_key")
  pendingLinqRecipientPhoneEncrypted String?  @map("pending_linq_recipient_phone_encrypted")
  telegramUserLookupKey          String?      @unique @map("telegram_user_lookup_key")
  telegramUserIdEncrypted        String?      @map("telegram_user_id_encrypted")
  createdAt                      DateTime     @default(now()) @map("created_at")
  updatedAt                      DateTime     @updatedAt @map("updated_at")
  member                         HostedMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([linqRecipientPhoneLookupKey])
  @@index([pendingLinqRecipientPhoneLookupKey])
  @@map("hosted_member_routing")
}

model HostedMemberBillingRef {
  memberId                      String       @unique @map("member_id")
  stripeCustomerLookupKey       String?      @unique @map("stripe_customer_lookup_key")
  stripeCustomerIdEncrypted     String?      @map("stripe_customer_id_encrypted")
  stripeSubscriptionLookupKey   String?      @unique @map("stripe_subscription_lookup_key")
  stripeSubscriptionIdEncrypted String?      @map("stripe_subscription_id_encrypted")
  createdAt                     DateTime     @default(now()) @map("created_at")
  updatedAt                     DateTime     @updatedAt @map("updated_at")
  member                        HostedMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("hosted_member_billing_ref")
}

model HostedInvite {
  id         String                  @id
  memberId   String                  @map("member_id")
  inviteCode String                  @unique @map("invite_code")
  channel    String                  @default("linq")
  sentAt     DateTime?               @map("sent_at")
  expiresAt  DateTime                @map("expires_at")
  createdAt  DateTime                @default(now()) @map("created_at")
  updatedAt  DateTime                @updatedAt @map("updated_at")
  member     HostedMember            @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([expiresAt])
  @@map("hosted_invite")
}

model HostedStripeEvent {
  eventId          String                  @id @map("event_id")
  type             String
  stripeCreatedAt  DateTime                @map("stripe_created_at")
  receivedAt       DateTime                @map("received_at")
  status           HostedStripeEventStatus @default(pending)
  attemptCount     Int                     @default(0) @map("attempt_count")
  nextAttemptAt    DateTime                @default(now()) @map("next_attempt_at")
  claimExpiresAt   DateTime?               @map("claim_expires_at")
  processedAt      DateTime?               @map("processed_at")
  lastErrorCode    String?                 @map("last_error_code")
  lastErrorMessage String?                 @map("last_error_message")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@index([status, stripeCreatedAt, createdAt])
  @@index([status, nextAttemptAt, stripeCreatedAt, createdAt])
  @@index([claimExpiresAt])
  @@map("hosted_stripe_event")
}

model HostedRevnetIssuance {
  id                       String                     @id
  memberId                 String                     @map("member_id")
  idempotencyKey           String                     @unique @map("idempotency_key")
  stripeInvoiceId          String                     @unique @map("stripe_invoice_id")
  stripePaymentIntentId    String?                    @map("stripe_payment_intent_id")
  stripeChargeId           String?                    @map("stripe_charge_id")
  chainId                  Int                        @map("chain_id")
  projectId                String                     @map("project_id")
  terminalAddress          String                     @map("terminal_address")
  paymentAssetAddress      String                     @map("payment_asset_address")
  beneficiaryAddress       String                     @map("beneficiary_address")
  stripePaymentAmountMinor Int                        @map("stripe_payment_amount_minor")
  stripePaymentCurrency    String                     @map("stripe_payment_currency")
  paymentAmount            String                     @map("payment_amount")
  status                   HostedRevnetIssuanceStatus @default(pending)
  attemptCount             Int                        @default(0) @map("attempt_count")
  nextAttemptAt            DateTime                   @default(now()) @map("next_attempt_at")
  payTxHash                String?                    @unique @map("pay_tx_hash")
  failureCode              String?                    @map("failure_code")
  failureMessage           String?                    @map("failure_message")
  submittedAt              DateTime?                  @map("submitted_at")
  confirmedAt              DateTime?                  @map("confirmed_at")
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")
  member                   HostedMember               @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@index([stripePaymentIntentId])
  @@index([stripeChargeId])
  @@map("hosted_revnet_issuance")
}

model HostedShareLink {
  id                 String    @id
  codeHash           String    @unique @map("code_hash")
  senderMemberId     String    @map("sender_member_id")
  previewJson        Json      @map("preview_json")
  expiresAt          DateTime  @map("expires_at")
  acceptedAt         DateTime? @map("accepted_at")
  acceptedByMemberId String?   @map("accepted_by_member_id")
  consumedAt         DateTime? @map("consumed_at")
  consumedByMemberId String?   @map("consumed_by_member_id")
  lastEventId        String?   @map("last_event_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([senderMemberId, createdAt])
  @@index([expiresAt])
  @@index([acceptedByMemberId, acceptedAt])
  @@index([consumedByMemberId, consumedAt])
  @@map("hosted_share_link")
}

model HostedWebhookReceipt {
  source            String
  eventId           String                            @map("event_id")
  status            HostedWebhookReceiptStatus
  attemptCount      Int                               @default(1) @map("attempt_count")
  version           Int                               @default(1)
  attemptId         String                            @map("attempt_id")
  firstReceivedAt   DateTime                          @map("first_received_at")
  lastReceivedAt    DateTime                          @map("last_received_at")
  plannedAt         DateTime?                         @map("planned_at")
  completedAt       DateTime?                         @map("completed_at")
  claimExpiresAt    DateTime?                         @map("claim_expires_at")
  lastErrorCode     String?                           @map("last_error_code")
  lastErrorMessage  String?                           @map("last_error_message")
  lastErrorName     String?                           @map("last_error_name")
  lastErrorRetryable Boolean?                         @map("last_error_retryable")
  createdAt         DateTime                          @default(now()) @map("created_at")
  updatedAt         DateTime                          @updatedAt @map("updated_at")
  sideEffects       HostedWebhookReceiptSideEffect[]

  @@id([source, eventId])
  @@index([firstReceivedAt])
  @@index([status, claimExpiresAt, firstReceivedAt])
  @@map("hosted_webhook_receipt")
}

model HostedWebhookReceiptSideEffect {
  source               String
  eventId              String                               @map("event_id")
  effectId             String                               @map("effect_id")
  kind                 HostedWebhookReceiptSideEffectKind
  status               HostedWebhookReceiptSideEffectStatus @default(pending)
  attemptCount         Int                                  @default(0) @map("attempt_count")
  lastAttemptAt        DateTime?                            @map("last_attempt_at")
  sentAt               DateTime?                            @map("sent_at")
  lastErrorCode        String?                              @map("last_error_code")
  lastErrorMessage     String?                              @map("last_error_message")
  lastErrorName        String?                              @map("last_error_name")
  lastErrorRetryable   Boolean?                             @map("last_error_retryable")
  payloadJson          Json                                 @map("payload_json")
  resultJson           Json?                                @map("result_json")
  createdAt            DateTime                             @default(now()) @map("created_at")
  updatedAt            DateTime                             @updatedAt @map("updated_at")
  receipt              HostedWebhookReceipt                 @relation(fields: [source, eventId], references: [source, eventId], onDelete: Cascade)

  @@id([source, eventId, effectId])
  @@index([source, eventId, status])
  @@map("hosted_webhook_receipt_side_effect")
}

model ExecutionOutbox {
  id             String                @id
  userId         String                @map("user_id")
  sourceType     String                @map("source_type")
  sourceId       String?               @map("source_id")
  eventId        String                @unique @map("event_id")
  eventKind      String                @map("event_kind")
  payloadJson    Json                  @map("payload_json")
  dispatchState  String                @default("queued") @map("dispatch_state")
  status         ExecutionOutboxStatus @default(queued)
  attemptCount   Int                   @default(0) @map("attempt_count")
  lastAttemptAt  DateTime?             @map("last_attempt_at")
  nextAttemptAt  DateTime?             @default(now()) @map("next_attempt_at")
  claimToken     String?               @map("claim_token")
  claimExpiresAt DateTime?             @map("claim_expires_at")
  lastError      String?               @map("last_error")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt, createdAt])
  @@index([userId, createdAt])
  @@map("execution_outbox")
}

model HostedAiUsage {
  id                    String       @id
  memberId              String       @map("member_id")
  sessionId             String       @map("session_id")
  turnId                String       @map("turn_id")
  attemptCount          Int          @map("attempt_count")
  occurredAt            DateTime     @map("occurred_at")
  provider              String
  routeId               String?      @map("route_id")
  requestedModel        String?      @map("requested_model")
  servedModel           String?      @map("served_model")
  providerName          String?      @map("provider_name")
  baseUrl               String?      @map("base_url")
  apiKeyEnv             String?      @map("api_key_env")
  credentialSource      String?      @map("credential_source")
  inputTokens           Int?         @map("input_tokens")
  outputTokens          Int?         @map("output_tokens")
  reasoningTokens       Int?         @map("reasoning_tokens")
  cachedInputTokens     Int?         @map("cached_input_tokens")
  cacheWriteTokens      Int?         @map("cache_write_tokens")
  totalTokens           Int?         @map("total_tokens")
  stripeMeterStatus     String       @default("pending") @map("stripe_meter_status")
  stripeMeteredAt       DateTime?    @map("stripe_metered_at")
  stripeMeterIdentifier String?      @map("stripe_meter_identifier")
  stripeMeterError      String?      @map("stripe_meter_error")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  member                HostedMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, occurredAt])
  @@index([stripeMeterStatus, occurredAt])
  @@index([turnId, attemptCount])
  @@map("hosted_ai_usage")
}

model HostedLinqDailyState {
  memberId             String       @map("member_id")
  dayUtc               DateTime     @map("day_utc")
  inboundCount         Int          @default(0) @map("inbound_count")
  outboundCount        Int          @default(0) @map("outbound_count")
  onboardingLinkSentAt DateTime?    @map("onboarding_link_sent_at")
  quotaReplySentAt     DateTime?    @map("quota_reply_sent_at")
  firstSeenAt          DateTime     @map("first_seen_at")
  lastSeenAt           DateTime     @map("last_seen_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  member               HostedMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([memberId, dayUtc])
  @@index([dayUtc])
  @@map("hosted_linq_daily_state")
}

model LinqRecipientBinding {
  id                 String             @id
  userId             String             @map("user_id")
  recipientPhone     String             @map("recipient_phone")
  recipientPhoneMask String?            @map("recipient_phone_mask")
  label              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  events             LinqWebhookEvent[]

  @@unique([recipientPhone])
  @@index([userId, recipientPhone])
  @@index([userId, recipientPhoneMask])
  @@map("linq_recipient_binding")
}

model LinqWebhookEvent {
  id             Int                  @id @default(autoincrement())
  userId         String               @map("user_id")
  bindingId      String               @map("binding_id")
  recipientPhone String               @map("recipient_phone")
  eventId        String               @unique @map("event_id")
  traceId        String?              @map("trace_id")
  eventType      String               @map("event_type")
  chatId         String?              @map("chat_id")
  messageId      String?              @map("message_id")
  occurredAt     DateTime?            @map("occurred_at")
  receivedAt     DateTime             @map("received_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  binding        LinqRecipientBinding @relation(fields: [bindingId], references: [id], onDelete: Cascade)

  @@index([userId, id])
  @@index([bindingId, id])
  @@index([recipientPhone, id])
  @@index([receivedAt])
  @@map("linq_webhook_event")
}
