generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeviceConnectionStatus {
  active
  reauthorization_required
  disconnected
}

model DeviceConnection {
  id                   String                 @id
  userId               String                 @map("user_id")
  provider             String
  externalAccountId    String                 @map("external_account_id")
  displayName          String?                @map("display_name")
  status               DeviceConnectionStatus @default(active)
  scopes               String[]               @default([])
  accessTokenExpiresAt DateTime?              @map("access_token_expires_at")
  metadataJson         Json                   @map("metadata_json")
  connectedAt          DateTime               @map("connected_at")
  lastWebhookAt        DateTime?              @map("last_webhook_at")
  lastSyncStartedAt    DateTime?              @map("last_sync_started_at")
  lastSyncCompletedAt  DateTime?              @map("last_sync_completed_at")
  lastSyncErrorAt      DateTime?              @map("last_sync_error_at")
  lastErrorCode        String?                @map("last_error_code")
  lastErrorMessage     String?                @map("last_error_message")
  nextReconcileAt      DateTime?              @map("next_reconcile_at")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  secret               DeviceConnectionSecret?
  signals              DeviceSyncSignal[]

  @@unique([provider, externalAccountId])
  @@index([userId, provider])
  @@map("device_connection")
}

model DeviceConnectionSecret {
  connectionId          String   @id @map("connection_id")
  accessTokenEncrypted  String   @map("access_token_encrypted")
  refreshTokenEncrypted String?  @map("refresh_token_encrypted")
  tokenVersion          Int      @default(1) @map("token_version")
  keyVersion            String   @map("key_version")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  connection            DeviceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("device_connection_secret")
}

model DeviceOauthSession {
  state        String   @id
  userId       String?  @map("user_id")
  provider     String
  returnTo     String?  @map("return_to")
  metadataJson Json     @map("metadata_json")
  createdAt    DateTime @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([expiresAt])
  @@index([userId, provider])
  @@map("device_oauth_session")
}

model DeviceWebhookTrace {
  provider          String
  traceId           String   @map("trace_id")
  externalAccountId String   @map("external_account_id")
  eventType         String   @map("event_type")
  receivedAt        DateTime @map("received_at")
  payloadJson       Json?    @map("payload_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@id([provider, traceId])
  @@index([provider, externalAccountId])
  @@index([receivedAt])
  @@map("device_webhook_trace")
}

model DeviceSyncSignal {
  id           Int               @id @default(autoincrement())
  userId       String            @map("user_id")
  connectionId String?           @map("connection_id")
  provider     String
  kind         String
  payloadJson  Json?             @map("payload_json")
  createdAt    DateTime          @default(now()) @map("created_at")
  connection   DeviceConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, id])
  @@index([connectionId])
  @@map("device_sync_signal")
}

model DeviceAgentSession {
  id                  String   @id
  userId              String   @map("user_id")
  label               String?
  tokenHash           String   @unique @map("token_hash")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  expiresAt           DateTime @map("expires_at")
  lastSeenAt          DateTime? @map("last_seen_at")
  revokedAt           DateTime? @map("revoked_at")
  revokeReason        String?  @map("revoke_reason")
  replacedBySessionId String?  @map("replaced_by_session_id")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([replacedBySessionId])
  @@map("device_agent_session")
}

model DeviceBrowserAssertionNonce {
  nonceHash String   @id @map("nonce_hash")
  userId    String   @map("user_id")
  method    String
  path      String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("device_browser_assertion_nonce")
}

enum HostedMemberStatus {
  invited
  registered
  active
  suspended
}

enum HostedInviteStatus {
  pending
  opened
  authenticated
  paid
  expired
}

enum HostedBillingStatus {
  not_started
  checkout_open
  active
  incomplete
  past_due
  canceled
  unpaid
  paused
}

enum HostedBillingMode {
  payment
  subscription
}

enum HostedBillingCheckoutStatus {
  open
  completed
  expired
  failed
}

enum HostedRevnetIssuanceStatus {
  pending
  submitting
  submitted
  confirmed
  failed
}

model HostedMember {
  id                           String              @id
  phoneNumber                  String              @map("phone_number")
  normalizedPhoneNumber        String              @unique @map("normalized_phone_number")
  phoneNumberVerifiedAt        DateTime?           @map("phone_number_verified_at")
  privyUserId                  String?             @unique @map("privy_user_id")
  walletAddress                String?             @unique @map("wallet_address")
  walletChainType              String?             @map("wallet_chain_type")
  walletProvider               String?             @map("wallet_provider")
  walletCreatedAt              DateTime?           @map("wallet_created_at")
  status                       HostedMemberStatus  @default(invited)
  billingStatus                HostedBillingStatus @default(not_started) @map("billing_status")
  billingMode                  HostedBillingMode?  @map("billing_mode")
  stripeCustomerId             String?             @unique @map("stripe_customer_id")
  stripeSubscriptionId         String?             @unique @map("stripe_subscription_id")
  stripeLatestCheckoutSessionId String?            @map("stripe_latest_checkout_session_id")
  linqChatId                   String?             @map("linq_chat_id")
  encryptedBootstrapSecret     String?             @map("encrypted_bootstrap_secret")
  encryptionKeyVersion         String?             @map("encryption_key_version")
  createdAt                    DateTime            @default(now()) @map("created_at")
  updatedAt                    DateTime            @updatedAt @map("updated_at")
  invites                      HostedInvite[]
  sessions                     HostedSession[]
  checkouts                    HostedBillingCheckout[]
  revnetIssuances              HostedRevnetIssuance[]

  @@index([status])
  @@index([billingStatus])
  @@map("hosted_member")
}

model HostedInvite {
  id              String             @id
  memberId        String             @map("member_id")
  inviteCode      String             @unique @map("invite_code")
  status          HostedInviteStatus @default(pending)
  channel         String             @default("linq")
  triggerText     String?            @map("trigger_text")
  linqEventId     String?            @map("linq_event_id")
  linqChatId      String?            @map("linq_chat_id")
  sentAt          DateTime?          @map("sent_at")
  openedAt        DateTime?          @map("opened_at")
  authenticatedAt DateTime?          @map("authenticated_at")
  paidAt          DateTime?          @map("paid_at")
  expiresAt       DateTime           @map("expires_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  member          HostedMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  checkouts       HostedBillingCheckout[]
  sessions        HostedSession[]

  @@index([memberId, createdAt])
  @@index([expiresAt])
  @@map("hosted_invite")
}

model HostedSession {
  id           String        @id
  memberId     String        @map("member_id")
  inviteId     String?       @map("invite_id")
  tokenHash    String        @unique @map("token_hash")
  userAgent    String?       @map("user_agent")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  expiresAt    DateTime      @map("expires_at")
  lastSeenAt   DateTime?     @map("last_seen_at")
  revokedAt    DateTime?     @map("revoked_at")
  revokeReason String?       @map("revoke_reason")
  member       HostedMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invite       HostedInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([inviteId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("hosted_session")
}

model HostedBillingCheckout {
  id                      String                      @id
  memberId                String                      @map("member_id")
  inviteId                String?                     @map("invite_id")
  stripeCheckoutSessionId String                      @unique @map("stripe_checkout_session_id")
  stripeCustomerId        String?                     @map("stripe_customer_id")
  stripeSubscriptionId    String?                     @map("stripe_subscription_id")
  priceId                 String                      @map("price_id")
  mode                    HostedBillingMode
  status                  HostedBillingCheckoutStatus @default(open)
  checkoutUrl             String?                     @map("checkout_url")
  amountTotal             Int?                        @map("amount_total")
  currency                String?                     @map("currency")
  createdAt               DateTime                    @default(now()) @map("created_at")
  completedAt             DateTime?                   @map("completed_at")
  expiredAt               DateTime?                   @map("expired_at")
  member                  HostedMember                @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invite                  HostedInvite?               @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([memberId, createdAt])
  @@index([inviteId, createdAt])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("hosted_billing_checkout")
}

model HostedRevnetIssuance {
  id                    String                     @id
  memberId              String                     @map("member_id")
  idempotencyKey        String                     @unique @map("idempotency_key")
  stripeInvoiceId       String                     @unique @map("stripe_invoice_id")
  stripePaymentIntentId String?                    @map("stripe_payment_intent_id")
  stripeChargeId        String?                    @map("stripe_charge_id")
  chainId               Int                        @map("chain_id")
  projectId             String                     @map("project_id")
  terminalAddress       String                     @map("terminal_address")
  tokenAddress          String                     @map("token_address")
  beneficiaryAddress    String                     @map("beneficiary_address")
  paymentAmountMinor    Int                        @map("payment_amount_minor")
  paymentCurrency       String                     @map("payment_currency")
  terminalTokenAmount   String                     @map("terminal_token_amount")
  status                HostedRevnetIssuanceStatus @default(pending)
  approvalTxHash        String?                    @unique @map("approval_tx_hash")
  payTxHash             String?                    @unique @map("pay_tx_hash")
  failureCode           String?                    @map("failure_code")
  failureMessage        String?                    @map("failure_message")
  submittedAt           DateTime?                  @map("submitted_at")
  confirmedAt           DateTime?                  @map("confirmed_at")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")
  member                HostedMember               @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
  @@index([status, createdAt])
  @@index([stripePaymentIntentId])
  @@index([stripeChargeId])
  @@map("hosted_revnet_issuance")
}

model HostedShareLink {
  id                 String   @id
  codeHash           String   @unique @map("code_hash")
  senderMemberId     String?  @map("sender_member_id")
  previewTitle       String   @map("preview_title")
  previewJson        Json?    @map("preview_json")
  encryptedPayload   String   @map("encrypted_payload")
  encryptionKeyVersion String @map("encryption_key_version")
  expiresAt          DateTime @map("expires_at")
  acceptedAt         DateTime? @map("accepted_at")
  acceptedByMemberId String?  @map("accepted_by_member_id")
  consumedAt         DateTime? @map("consumed_at")
  consumedByMemberId String?  @map("consumed_by_member_id")
  lastEventId        String?  @map("last_event_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([senderMemberId, createdAt])
  @@index([expiresAt])
  @@index([acceptedByMemberId, acceptedAt])
  @@index([consumedByMemberId, consumedAt])
  @@map("hosted_share_link")
}

model HostedWebhookReceipt {
  source          String
  eventId         String   @map("event_id")
  firstReceivedAt DateTime @map("first_received_at")
  payloadJson     Json?    @map("payload_json")
  createdAt       DateTime @default(now()) @map("created_at")

  @@id([source, eventId])
  @@index([firstReceivedAt])
  @@map("hosted_webhook_receipt")
}

model LinqRecipientBinding {
  id             String             @id
  userId         String             @map("user_id")
  recipientPhone String             @map("recipient_phone")
  label          String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  events         LinqWebhookEvent[]

  @@unique([recipientPhone])
  @@index([userId, recipientPhone])
  @@map("linq_recipient_binding")
}

model LinqWebhookEvent {
  id             Int                  @id @default(autoincrement())
  userId         String               @map("user_id")
  bindingId      String               @map("binding_id")
  recipientPhone String               @map("recipient_phone")
  eventId        String               @unique @map("event_id")
  traceId        String?              @map("trace_id")
  eventType      String               @map("event_type")
  chatId         String?              @map("chat_id")
  messageId      String?              @map("message_id")
  occurredAt     DateTime?            @map("occurred_at")
  receivedAt     DateTime             @map("received_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  binding        LinqRecipientBinding @relation(fields: [bindingId], references: [id], onDelete: Cascade)

  @@index([userId, id])
  @@index([bindingId, id])
  @@index([recipientPhone, id])
  @@index([receivedAt])
  @@map("linq_webhook_event")
}
