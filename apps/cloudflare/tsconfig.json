{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": "../..",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "lib": [
      "es2022",
      "webworker"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "sourceMap": false,
    "types": [
      "node",
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts"
  ]
}
