{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": "../..",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "lib": [
      "es2022",
      "webworker"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "sourceMap": false,
