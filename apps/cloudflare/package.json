{
  "name": "@healthybob/cloudflare-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "runner:local": "pnpm --dir ../.. exec tsx --tsconfig apps/cloudflare/tsconfig.json apps/cloudflare/src/runner-local.ts",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "pnpm typecheck && pnpm --dir ../.. exec vitest run --config apps/cloudflare/vitest.config.ts --no-coverage --maxWorkers 1",
    "runner:docker:build": "docker build -f ../../Dockerfile.cloudflare-hosted-runner -t healthybob-cloudflare-runner ../..",
    "runner:docker:run": "docker run --rm -p 8080:8080 --env-file .runner.env healthybob-cloudflare-runner",
    "worker:deploy": "pnpm exec wrangler deploy",
    "worker:dev": "pnpm exec wrangler dev"
  },
  "dependencies": {
    "@healthybob/device-syncd": "workspace:*",
    "healthybob": "workspace:*",
    "@healthybob/inboxd": "workspace:*",
    "@healthybob/parsers": "workspace:*",
    "@healthybob/runtime-state": "workspace:*",
    "@healthybob/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.68.0"
  }
}
