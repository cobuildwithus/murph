# Copy to apps/cloudflare/.runner.env when running the hosted runner container locally.
# For automated deploys, the GitHub Actions workflow renders this file shape into `apps/cloudflare/.deploy/runner.env`.
PORT=8080
HOSTED_EXECUTION_RUNNER_CONTROL_TOKEN=replace-me-with-the-same-runner-token
HOSTED_EXECUTION_RUNNER_COMMIT_TIMEOUT_MS=30000

# Optional allowlist extensions for encrypted per-user runner env overrides.
# The runner already permits a conservative built-in set of provider/model/channel keys,
# and these env vars let you extend that set without rebuilding the image.
# HOSTED_EXECUTION_ALLOWED_USER_ENV_KEYS=OPENAI_API_KEY,AGENTMAIL_API_KEY,TELEGRAM_BOT_TOKEN
# HOSTED_EXECUTION_ALLOWED_USER_ENV_PREFIXES=HB_USER_,OPENAI_,AGENTMAIL_,TELEGRAM_

# Optional global presets that apply to every hosted run unless a per-user encrypted
# override is present inside the user's agent-state bundle.
# DEVICE_SYNC_PUBLIC_BASE_URL=https://example.test
# DEVICE_SYNC_SECRET=replace-me
# WHOOP_CLIENT_ID=replace-me
# WHOOP_CLIENT_SECRET=replace-me
# OURA_CLIENT_ID=replace-me
# OURA_CLIENT_SECRET=replace-me
# LINQ_API_BASE_URL=https://api.linq.example.test/api/partner/v3
# LINQ_API_TOKEN=replace-me
# AGENTMAIL_API_BASE_URL=https://api.agentmail.example.test
# AGENTMAIL_API_KEY=replace-me
# TELEGRAM_BOT_TOKEN=replace-me
# TELEGRAM_BOT_USERNAME=replace-me
# TELEGRAM_WEBHOOK_SECRET=replace-me
# OPENAI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me
# GOOGLE_GENERATIVE_AI_API_KEY=replace-me
# OPENROUTER_API_KEY=replace-me
# TOGETHER_API_KEY=replace-me
# GROQ_API_KEY=replace-me
# XAI_API_KEY=replace-me
# MISTRAL_API_KEY=replace-me

# Optional parser/model cache presets baked into the runner image by default.
# Override these only if you mount or bake models into different locations.
# WHISPER_MODEL=base
# WHISPER_MODEL_DIR=/root/.healthybob/models/whisper
# PADDLEOCR_MODEL_DIR=/root/.healthybob/models/paddleocr
# PARSER_FFMPEG_PATH=/usr/bin/ffmpeg
