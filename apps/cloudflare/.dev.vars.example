# Copy to apps/cloudflare/.dev.vars for wrangler dev or set these as real Cloudflare secrets/vars.
# This local scaffold mirrors the current hosted architecture:
# - Vercel OIDC authenticates the web -> Cloudflare control edge.
# - HOSTED_WEB_INTERNAL_SIGNING_SECRET authenticates the narrow signed Cloudflare <-> web service seam.
# - Hosted bundle/env/journal objects use the platform envelope key.
# - Managed user provisioning creates automation + recovery recipients today and may add tee-automation later.
# - Future browser-generated user-unlock recipients are intentionally not worker env material and are preserved on envelope reconciliation.

HOSTED_EXECUTION_PLATFORM_ENVELOPE_KEY=replace-me-with-a-base64-32-byte-key
HOSTED_EXECUTION_PLATFORM_ENVELOPE_KEY_ID=v1
HOSTED_EXECUTION_AUTOMATION_RECIPIENT_KEY_ID=automation:v1
HOSTED_EXECUTION_AUTOMATION_RECIPIENT_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"replace-me-base64url-private-scalar","x":"replace-me-base64url-x-coordinate","y":"replace-me-base64url-y-coordinate"}
HOSTED_EXECUTION_AUTOMATION_RECIPIENT_PUBLIC_JWK={"kty":"EC","crv":"P-256","x":"replace-me-base64url-x-coordinate","y":"replace-me-base64url-y-coordinate"}
HOSTED_EXECUTION_RECOVERY_RECIPIENT_KEY_ID=recovery:v1
HOSTED_EXECUTION_RECOVERY_RECIPIENT_PUBLIC_JWK={"kty":"EC","crv":"P-256","x":"replace-me-base64url-x-coordinate","y":"replace-me-base64url-y-coordinate"}
# Optional overlapping private-key rotation set. Entries are keyed by recipient key id.
# HOSTED_EXECUTION_AUTOMATION_RECIPIENT_PRIVATE_KEYRING_JSON={"automation:v0":{"kty":"EC","crv":"P-256","d":"replace-me-base64url-private-scalar","x":"replace-me-base64url-x-coordinate","y":"replace-me-base64url-y-coordinate"}}
# Optional overlapping platform-envelope rotation set. Entries are keyed by platform key id.
# HOSTED_EXECUTION_PLATFORM_ENVELOPE_KEYRING_JSON={"v0":"replace-me-with-a-base64-32-byte-key"}
# Optional future enclave-only automation recipient. Configure both fields together or leave both unset.
# HOSTED_EXECUTION_TEE_AUTOMATION_RECIPIENT_KEY_ID=tee-automation:v1
# HOSTED_EXECUTION_TEE_AUTOMATION_RECIPIENT_PUBLIC_JWK={"kty":"EC","crv":"P-256","x":"replace-me-base64url-x-coordinate","y":"replace-me-base64url-y-coordinate"}

HOSTED_EXECUTION_VERCEL_OIDC_TEAM_SLUG=replace-me-with-your-vercel-team-slug
HOSTED_EXECUTION_VERCEL_OIDC_PROJECT_NAME=replace-me-with-your-vercel-project-name
HOSTED_EXECUTION_VERCEL_OIDC_ENVIRONMENT=production
HOSTED_WEB_INTERNAL_SIGNING_SECRET=replace-me-with-a-random-shared-secret
HOSTED_WEB_BASE_URL=https://your-hosted-web.example.com

HOSTED_EXECUTION_DEFAULT_ALARM_DELAY_MS=21600000
HOSTED_EXECUTION_MAX_EVENT_ATTEMPTS=3
HOSTED_EXECUTION_RETRY_DELAY_MS=30000
HOSTED_EXECUTION_RUNNER_COMMIT_TIMEOUT_MS=30000
HOSTED_EXECUTION_RUNNER_TIMEOUT_MS=60000

# Required for web <-> worker control in local dev.
HOSTED_EXECUTION_DISPATCH_URL=http://127.0.0.1:8787
VERCEL_PROJECT_PRODUCTION_URL=http://127.0.0.1:3000

# Optional explicit native-container size for local/generated Wrangler config.
# Supported values are the named Wrangler presets such as `basic` or a JSON object like:
# CF_CONTAINER_INSTANCE_TYPE={"vcpu":0.5,"memory_mib":2048,"disk_mb":8192}
# CF_CONTAINER_INSTANCE_TYPE=basic

# Add any optional provider/runtime vars or secrets you need for wrangler dev here. The checked-in
# local scaffold no longer filters `.dev.vars` through `secrets.required`.
# OPENAI_API_KEY=...
# AGENTMAIL_API_KEY=...
# TELEGRAM_BOT_TOKEN=...

# Optional hosted email bridge settings for Cloudflare Email Routing + Email Sending.
# Keep these as operator-level Worker vars/secrets rather than per-user env overrides.
# HOSTED_EMAIL_DOMAIN=mail.example.test
# HOSTED_EMAIL_LOCAL_PART=assistant
# HOSTED_EMAIL_FROM_ADDRESS=assistant@mail.example.test
# HOSTED_EMAIL_SIGNING_SECRET=replace-me-with-a-random-email-routing-secret
# HOSTED_EMAIL_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# HOSTED_EMAIL_CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-with-email-sending-access
# HOSTED_EMAIL_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
# HOSTED_EMAIL_DEFAULT_SUBJECT=Murph update

# Optional explicit hosted assistant seed for member activation.
# These are operator-level Worker vars, not per-user env overrides. The hosted runtime persists
# the selected active profile into ~/.murph/config.json during bootstrap so later runs stay explicit.
# HOSTED_ASSISTANT_PROVIDER=openai
# HOSTED_ASSISTANT_MODEL=gpt-4.1-mini
# HOSTED_ASSISTANT_BASE_URL=https://api.openai.com/v1
# HOSTED_ASSISTANT_API_KEY_ENV=OPENAI_API_KEY
# HOSTED_ASSISTANT_PROVIDER_NAME=openai
# HOSTED_ASSISTANT_CODEX_COMMAND=codex
# HOSTED_ASSISTANT_APPROVAL_POLICY=on-request
# HOSTED_ASSISTANT_SANDBOX=workspace-write
# HOSTED_ASSISTANT_PROFILE=default
# HOSTED_ASSISTANT_REASONING_EFFORT=medium
# HOSTED_ASSISTANT_OSS=false

# Optional allowlist extensions for encrypted per-user runner env overrides.
# Keep these in sync with the native container runtime when you extend the exact-key allowlist.
# HOSTED_EXECUTION_ALLOWED_USER_ENV_KEYS=OPENAI_API_KEY,AGENTMAIL_API_KEY,TELEGRAM_BOT_TOKEN
