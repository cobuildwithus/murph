# Copy to apps/cloudflare/.dev.vars for wrangler dev or set these as real Cloudflare secrets/vars.
# The control tokens are required for protected worker and container routes; local dev now fails closed
# when either token set is missing. Use comma-separated token sets so you can overlap old/new values during rotation.

HOSTED_EXECUTION_SIGNING_SECRET=replace-me-with-a-random-shared-secret
HOSTED_EXECUTION_BUNDLE_ENCRYPTION_KEY=replace-me-with-a-base64-32-byte-key
HOSTED_EXECUTION_BUNDLE_ENCRYPTION_KEY_ID=v1
HOSTED_EXECUTION_CONTROL_TOKENS=replace-me-with-the-current-operator-token,replace-me-with-the-previous-operator-token
HOSTED_EXECUTION_DEFAULT_ALARM_DELAY_MS=21600000
HOSTED_EXECUTION_MAX_EVENT_ATTEMPTS=3
HOSTED_EXECUTION_RETRY_DELAY_MS=30000
HOSTED_EXECUTION_RUNNER_CONTROL_TOKENS=replace-me-with-the-current-runner-token,replace-me-with-the-previous-runner-token
HOSTED_EXECUTION_RUNNER_COMMIT_TIMEOUT_MS=30000
HOSTED_EXECUTION_RUNNER_TIMEOUT_MS=60000

# Optional explicit native-container size for local/generated Wrangler config.
# Supported values are the named Wrangler presets such as `basic` or a JSON object like:
# CF_CONTAINER_INSTANCE_TYPE={"vcpu":0.5,"memory_mib":2048,"disk_mb":8192}
# CF_CONTAINER_INSTANCE_TYPE=basic

# Add any optional provider/runtime vars or secrets you need for wrangler dev here. The checked-in
# local scaffold no longer filters `.dev.vars` through `secrets.required`.
# OPENAI_API_KEY=...
# AGENTMAIL_API_KEY=...
# TELEGRAM_BOT_TOKEN=...

# Optional hosted email bridge settings for Cloudflare Email Routing + Email Sending.
# Keep these as operator-level Worker vars/secrets rather than per-user env overrides.
# HOSTED_EMAIL_DOMAIN=mail.example.test
# HOSTED_EMAIL_LOCAL_PART=assistant
# HOSTED_EMAIL_FROM_ADDRESS=assistant@mail.example.test
# HOSTED_EMAIL_SIGNING_SECRET=replace-me-with-a-random-email-routing-secret
# HOSTED_EMAIL_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# HOSTED_EMAIL_CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-with-email-sending-access
# HOSTED_EMAIL_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
# HOSTED_EMAIL_DEFAULT_SUBJECT=Murph update

# Optional explicit hosted assistant seed for member activation.
# These are operator-level Worker vars, not per-user env overrides. The hosted runtime persists
# the selected active profile into ~/.murph/config.json during bootstrap so later runs stay explicit.
# HOSTED_ASSISTANT_PROVIDER=openai
# HOSTED_ASSISTANT_MODEL=gpt-4.1-mini
# HOSTED_ASSISTANT_BASE_URL=https://api.openai.com/v1
# HOSTED_ASSISTANT_API_KEY_ENV=OPENAI_API_KEY
# HOSTED_ASSISTANT_PROVIDER_NAME=openai
# HOSTED_ASSISTANT_CODEX_COMMAND=codex
# HOSTED_ASSISTANT_APPROVAL_POLICY=on-request
# HOSTED_ASSISTANT_SANDBOX=workspace-write
# HOSTED_ASSISTANT_PROFILE=default
# HOSTED_ASSISTANT_REASONING_EFFORT=medium
# HOSTED_ASSISTANT_OSS=false

# Optional allowlist extensions for encrypted per-user runner env overrides.
# Keep these in sync with the native container runtime when you extend the exact-key allowlist.
# HOSTED_EXECUTION_ALLOWED_USER_ENV_KEYS=OPENAI_API_KEY,AGENTMAIL_API_KEY,TELEGRAM_BOT_TOKEN

# Optional worker-to-web bearer token sets for internal callbacks.
# HOSTED_EXECUTION_INTERNAL_TOKENS=replace-me-with-the-current-web-internal-token,replace-me-with-the-previous-web-internal-token
# HOSTED_SHARE_INTERNAL_TOKENS=replace-me-with-the-current-share-internal-token,replace-me-with-the-previous-share-internal-token
