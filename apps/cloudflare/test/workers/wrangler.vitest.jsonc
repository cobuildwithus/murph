{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "hosted-runner-vitest",
  "main": "./worker-entry.ts",
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_RUNNER",
        "class_name": "VitestUserRunnerDurableObject"
      },
      {
        "name": "RUNNER_CONTAINER",
        "class_name": "RunnerContainerTestDouble"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["VitestUserRunnerDurableObject"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["RunnerContainerTestDouble"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUNDLES",
      "bucket_name": "hosted-runner-vitest-bundles"
    }
  ],
  "vars": {
    "HOSTED_EXECUTION_AUTOMATION_RECIPIENT_KEY_ID": "automation:v1",
    "HOSTED_EXECUTION_AUTOMATION_RECIPIENT_PRIVATE_JWK": "{\"crv\":\"P-256\",\"ext\":true,\"key_ops\":[\"deriveBits\"],\"kty\":\"EC\",\"x\":\"xSelVJv6r6LPUS8GCNgj1T_7z5GXOrhgY1cCdzGb5ao\",\"y\":\"8HhciS1cAPKs_fPfgZnb1USdRtBX-4Nvp8XiBHuMcmY\",\"d\":\"HAPljluiFVW3g-UEmrJ9NVYTlclAhaC8N5LT0h7vitQ\"}",
    "HOSTED_EXECUTION_AUTOMATION_RECIPIENT_PUBLIC_JWK": "{\"crv\":\"P-256\",\"ext\":true,\"key_ops\":[],\"kty\":\"EC\",\"x\":\"xSelVJv6r6LPUS8GCNgj1T_7z5GXOrhgY1cCdzGb5ao\",\"y\":\"8HhciS1cAPKs_fPfgZnb1USdRtBX-4Nvp8XiBHuMcmY\"}",
    "HOSTED_EXECUTION_BUNDLE_ENCRYPTION_KEY": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
    "HOSTED_EXECUTION_BUNDLE_ENCRYPTION_KEY_ID": "v1",
    "HOSTED_EXECUTION_DEFAULT_ALARM_DELAY_MS": "60000",
    "HOSTED_EXECUTION_MAX_EVENT_ATTEMPTS": "3",
    "HOSTED_EXECUTION_RETRY_DELAY_MS": "1000",
    "HOSTED_EXECUTION_RUNNER_CONTROL_TOKEN": "runner-token",
    "HOSTED_EXECUTION_RUNNER_TIMEOUT_MS": "120000",
    "HOSTED_EXECUTION_SIGNING_SECRET": "dispatch-secret",
    "MURPH_HOSTED_EXECUTION_STDIO_LOGS": "0",
    "VITEST": "true"
  }
}
